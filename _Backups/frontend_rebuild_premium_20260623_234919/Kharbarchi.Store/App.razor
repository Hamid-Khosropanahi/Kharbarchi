<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Shared.StoreLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(Shared.StoreLayout)">
            <section class="store-hero"><h1>صفحه پیدا نشد</h1><p>آدرس وارد شده در فروشگاه قدیمی وجود ندارد.</p></section>
        </LayoutView>
    </NotFound>
</Router>
