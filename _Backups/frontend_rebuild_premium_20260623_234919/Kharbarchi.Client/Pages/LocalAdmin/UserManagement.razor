@page "/local-admin/users"
@attribute [Authorize(Roles = KharbarchiRoles.SuperAdmins)]
@using System.ComponentModel.DataAnnotations
@using Kharbarchi.Client.Services
@using Kharbarchi.Shared.Contracts
@using Kharbarchi.Shared.Security
@using Microsoft.AspNetCore.Authorization
@inject UserAdminService UserAdmin

<PageTitle>مدیریت کاربران و نقش‌ها</PageTitle>

<div class="khb-admin-shell" dir="rtl">
    <section class="khb-admin-hero khb-admin-hero-compact">
        <div>
            <span class="khb-eyebrow">مدیر کل</span>
            <h1>کاربران و دسترسی‌ها</h1>
            <p>ساخت اکانت داخلی، تخصیص نقش، ریست رمز و قفل/فعال‌سازی کاربر فقط از این صفحه انجام می‌شود.</p>
        </div>
        <a class="khb-secondary-btn" href="/local-admin">بازگشت به داشبورد</a>
    </section>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="khb-alert @(isError ? "khb-alert-danger" : "khb-alert-success")">@message</div>
    }

    <section class="khb-two-column">
        <div class="khb-panel">
            <h2>ساخت کاربر جدید</h2>
            <EditForm Model="createModel" OnValidSubmit="CreateUserAsync" class="khb-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <label>
                    نام کاربری انگلیسی
                    <InputText class="khb-input" @bind-Value="createModel.UserName" />
                </label>

                <label>
                    نام کامل
                    <InputText class="khb-input" @bind-Value="createModel.FullName" />
                </label>

                <label>
                    ایمیل
                    <InputText class="khb-input" @bind-Value="createModel.Email" />
                </label>

                <label>
                    رمز عبور
                    <InputText type="password" class="khb-input" @bind-Value="createModel.Password" />
                </label>

                <label>
                    تکرار رمز عبور
                    <InputText type="password" class="khb-input" @bind-Value="createModel.ConfirmPassword" />
                </label>

                <div class="khb-role-selector">
                    <strong>نقش‌ها</strong>
                    @foreach (var role in roles)
                    {
                        <label class="khb-check-card">
                            <input type="checkbox" checked="@createModel.SelectedRoles.Contains(role.Name)" @onchange="e => ToggleCreateRole(role.Name, e.Value)" />
                            <span>
                                <b>@role.PersianName</b>
                                <small>@role.Description</small>
                            </span>
                        </label>
                    }
                </div>

                <button class="khb-primary-btn" type="submit" disabled="@isBusy">ساخت کاربر</button>
            </EditForm>
        </div>

    </section>

    <section class="khb-panel khb-users-panel">
        <div class="khb-panel-heading">
            <h2>کاربران سیستم</h2>
            <button class="khb-secondary-btn" @onclick="LoadAsync" disabled="@isBusy">بارگیری مجدد</button>
        </div>

        @if (isLoading)
        {
            <p>در حال بارگیری کاربران...</p>
        }
        else
        {
            <div class="khb-user-list">
                @foreach (var user in users)
                {
                    <article class="khb-user-card">
                        <header>
                            <div>
                                <strong>@user.UserName</strong>
                                <p>@(string.IsNullOrWhiteSpace(user.FullName) ? "بدون نام کامل" : user.FullName)</p>
                                <small>@(string.IsNullOrWhiteSpace(user.Email) ? "بدون ایمیل" : user.Email)</small>
                            </div>
                            <span class="@(user.IsLockedOut ? "khb-status-danger" : "khb-status-ok")">
                                @(user.IsLockedOut ? "قفل شده" : "فعال")
                            </span>
                        </header>

                        <div class="khb-role-selector khb-role-selector-inline">
                            @foreach (var role in roles)
                            {
                                <label class="khb-check-card">
                                    <input type="checkbox" checked="@selectedRoles[user.Id].Contains(role.Name)" @onchange="e => ToggleUserRole(user.Id, role.Name, e.Value)" />
                                    <span><b>@role.PersianName</b></span>
                                </label>
                            }
                        </div>

                        <footer>
                            <button class="khb-primary-btn khb-small-btn" @onclick="() => SaveRolesAsync(user.Id)" disabled="@isBusy">ذخیره نقش‌ها</button>
                            <button class="khb-secondary-btn khb-small-btn" @onclick="() => ResetPasswordAsync(user.Id)" disabled="@isBusy">ریست رمز تست</button>
                            <button class="khb-danger-btn khb-small-btn" @onclick="() => ToggleLockAsync(user)" disabled="@isBusy">
                                @(user.IsLockedOut ? "فعال‌سازی" : "قفل کردن")
                            </button>
                        </footer>
                    </article>
                }
            </div>
        }
    </section>
</div>

@code {
    private readonly CreateUserFormModel createModel = new();
    private readonly Dictionary<string, HashSet<string>> selectedRoles = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<LocalRoleDto> roles = [];
    private IReadOnlyList<LocalUserDto> users = [];
    private bool isLoading = true;
    private bool isBusy;
    private bool isError;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        message = null;

        try
        {
            roles = await UserAdmin.GetRolesAsync();
            users = await UserAdmin.GetUsersAsync();
            selectedRoles.Clear();
            foreach (var user in users)
            {
                selectedRoles[user.Id] = new HashSet<string>(user.Roles, StringComparer.OrdinalIgnoreCase);
            }
        }
        catch (Exception ex)
        {
            isError = true;
            message = "خطا در بارگیری کاربران: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateUserAsync()
    {
        isBusy = true;
        isError = false;
        message = null;

        try
        {
            var request = new CreateLocalUserRequest
            {
                UserName = createModel.UserName,
                Email = createModel.Email,
                FullName = createModel.FullName,
                Password = createModel.Password,
                ConfirmPassword = createModel.ConfirmPassword,
                Roles = createModel.SelectedRoles.OrderBy(x => x).ToList()
            };

            var result = await UserAdmin.CreateUserAsync(request);
            isError = !result.IsSuccess;
            message = result.Message;

            if (result.IsSuccess)
            {
                createModel.Clear();
                await LoadAsync();
            }
        }
        finally
        {
            isBusy = false;
        }
    }

    private void ToggleCreateRole(string role, object? value)
    {
        var isChecked = value is bool b && b;
        if (isChecked)
        {
            createModel.SelectedRoles.Add(role);
        }
        else
        {
            createModel.SelectedRoles.Remove(role);
        }
    }

    private void ToggleUserRole(string userId, string role, object? value)
    {
        if (!selectedRoles.TryGetValue(userId, out var set))
        {
            set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            selectedRoles[userId] = set;
        }

        var isChecked = value is bool b && b;
        if (isChecked)
        {
            set.Add(role);
        }
        else
        {
            set.Remove(role);
        }
    }

    private async Task SaveRolesAsync(string userId)
    {
        isBusy = true;
        isError = false;
        message = null;

        try
        {
            var rolesToSave = selectedRoles.TryGetValue(userId, out var set) ? set.OrderBy(x => x).ToList() : [];
            var result = await UserAdmin.UpdateRolesAsync(userId, rolesToSave);
            isError = !result.IsSuccess;
            message = result.Message;
            if (result.IsSuccess)
            {
                await LoadAsync();
            }
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ResetPasswordAsync(string userId)
    {
        await Task.CompletedTask;
        isError = true;
        message = "Archived UI: enter a new password through the current user-management page.";
    }

    private async Task ToggleLockAsync(LocalUserDto user)
    {
        isBusy = true;
        isError = false;
        var result = await UserAdmin.SetLockStateAsync(user.Id, !user.IsLockedOut);
        isError = !result.IsSuccess;
        message = result.Message;
        if (result.IsSuccess)
        {
            await LoadAsync();
        }
        isBusy = false;
    }

    private sealed class CreateUserFormModel
    {
        [Required(ErrorMessage = "نام کاربری الزامی است.")]
        public string UserName { get; set; } = string.Empty;

        public string? Email { get; set; }
        public string? FullName { get; set; }

        [Required(ErrorMessage = "رمز عبور الزامی است.")]
        [StringLength(200, MinimumLength = 10, ErrorMessage = "رمز عبور باید حداقل ۱۰ کاراکتر باشد.")]
        public string Password { get; set; } = string.Empty;

        [Compare(nameof(Password), ErrorMessage = "تکرار رمز عبور با رمز اصلی یکی نیست.")]
        public string ConfirmPassword { get; set; } = string.Empty;

        public HashSet<string> SelectedRoles { get; } = new(StringComparer.OrdinalIgnoreCase);

        public void Clear()
        {
            UserName = string.Empty;
            Email = null;
            FullName = null;
            Password = string.Empty;
            ConfirmPassword = string.Empty;
            SelectedRoles.Clear();
        }
    }
}
