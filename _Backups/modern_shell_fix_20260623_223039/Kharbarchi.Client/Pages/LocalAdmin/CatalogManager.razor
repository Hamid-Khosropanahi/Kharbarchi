@page "/local-admin/catalog"
@attribute [Authorize(Roles = "SuperAdmin,Admin,PricingManager")]
@using Kharbarchi.Client.Services
@using Kharbarchi.Shared.Contracts
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@inject CatalogAdminClient CatalogClient

<PageTitle>مدیریت محصولات خواربارچی</PageTitle>

<div class="khb-admin-shell" dir="rtl">
    <header class="khb-admin-header">
        <div>
            <span class="khb-eyebrow">سیستم لوکال خواربارچی</span>
            <h1>ساخت محصول، برند، کالای اصلی، تگ و مشخصات</h1>
            <p>این فرم فقط داخل شبکه لوکال اجرا می‌شود. اطلاعات پس از تایید نقش‌ها وارد صف ارسال مرکزی می‌شود.</p>
        </div>
        <button class="khb-btn khb-btn-soft" @onclick="LoadAsync">بروزرسانی اطلاعات</button>
    </header>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="khb-alert">@message</div>
    }

    <section class="khb-grid khb-grid-4">
        <EditForm Model="brandForm" OnValidSubmit="CreateBrandAsync" class="khb-card">
            <DataAnnotationsValidator />
            <h2>برند جدید</h2>
            <label>نام برند</label>
            <InputText class="khb-input" @bind-Value="brandForm.Name" />
            <label>اسلاگ انگلیسی</label>
            <InputText class="khb-input" @bind-Value="brandForm.Slug" />
            <label>لوگو</label>
            <InputText class="khb-input" @bind-Value="brandForm.LogoUrl" />
            <button class="khb-btn" type="submit">ثبت برند</button>
        </EditForm>

        <EditForm Model="commodityForm" OnValidSubmit="CreateCommodityAsync" class="khb-card">
            <DataAnnotationsValidator />
            <h2>کالای اصلی</h2>
            <label>نام فارسی</label>
            <InputText class="khb-input" @bind-Value="commodityForm.Name" />
            <label>نام انگلیسی</label>
            <InputText class="khb-input" @bind-Value="commodityForm.EnglishName" />
            <label>اسلاگ</label>
            <InputText class="khb-input" @bind-Value="commodityForm.Slug" />
            <button class="khb-btn" type="submit">ثبت کالای اصلی</button>
        </EditForm>

        <EditForm Model="tagForm" OnValidSubmit="CreateTagAsync" class="khb-card">
            <DataAnnotationsValidator />
            <h2>تگ محصول</h2>
            <label>نام تگ</label>
            <InputText class="khb-input" @bind-Value="tagForm.Name" />
            <label>اسلاگ</label>
            <InputText class="khb-input" @bind-Value="tagForm.Slug" />
            <button class="khb-btn" type="submit">ثبت تگ</button>
        </EditForm>

        <EditForm Model="specForm" OnValidSubmit="CreateSpecAsync" class="khb-card">
            <DataAnnotationsValidator />
            <h2>مشخصه کالا</h2>
            <label>نام مشخصه</label>
            <InputText class="khb-input" @bind-Value="specForm.Name" />
            <label>واحد</label>
            <InputText class="khb-input" @bind-Value="specForm.Unit" />
            <label>ترتیب</label>
            <InputNumber class="khb-input" @bind-Value="specForm.SortOrder" />
            <button class="khb-btn" type="submit">ثبت مشخصه</button>
        </EditForm>
    </section>

    <section class="khb-card khb-card-wide">
        <div class="khb-section-title">
            <h2>فرم کامل محصول</h2>
            <span>قیمت فروش مستقل است؛ هیچ فرمول کیلویی روی قیمت اعمال نمی‌شود.</span>
        </div>

        <EditForm Model="productForm" OnValidSubmit="SaveProductAsync">
            <DataAnnotationsValidator />
            <div class="khb-form-grid">
                <div>
                    <label>نام محصول</label>
                    <InputText class="khb-input" @bind-Value="productForm.Name" />
                </div>
                <div>
                    <label>SKU</label>
                    <InputText class="khb-input" @bind-Value="productForm.Sku" />
                </div>
                <div>
                    <label>دسته‌بندی</label>
                    <InputSelect class="khb-input" @bind-Value="productForm.CategoryId">
                        <option value="0">انتخاب کنید</option>
                        @foreach (var item in lookups.Categories)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </InputSelect>
                </div>
                <div>
                    <label>برند</label>
                    <InputSelect class="khb-input" @bind-Value="productForm.BrandId">
                        <option value="">بدون برند</option>
                        @foreach (var item in lookups.Brands)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </InputSelect>
                </div>
                <div>
                    <label>کالای اصلی</label>
                    <InputSelect class="khb-input" @bind-Value="productForm.CommodityId">
                        <option value="">بدون کالای اصلی</option>
                        @foreach (var item in lookups.Commodities)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </InputSelect>
                </div>
                <div>
                    <label>قیمت فروش</label>
                    <InputNumber class="khb-input" @bind-Value="productForm.Price" />
                </div>
                <AuthorizeView Roles="SuperAdmin,Admin,PricingManager" Context="authContext">
                    <div>
                        <label>قیمت خرید داخلی</label>
                        <InputNumber class="khb-input" @bind-Value="productForm.PurchasePrice" />
                    </div>
                </AuthorizeView>
                <div>
                    <label>موجودی فعلی</label>
                    <InputNumber class="khb-input" @bind-Value="productForm.StockQuantity" />
                </div>
                <div>
                    <label>شناسه محصول WooCommerce</label>
                    <InputNumber class="khb-input" @bind-Value="productForm.WooCommerceProductId" />
                </div>
                <div class="khb-col-span-2">
                    <label>آدرس تصویر</label>
                    <InputText class="khb-input" @bind-Value="productForm.ImageUrl" />
                </div>
                <div class="khb-col-span-2">
                    <label>توضیحات</label>
                    <InputTextArea class="khb-input khb-textarea" @bind-Value="productForm.Description" />
                </div>
            </div>

            <div class="khb-chip-panel">
                <h3>تگ‌ها</h3>
                @foreach (var tag in lookups.Tags)
                {
                    <label class="khb-chip">
                        <input type="checkbox" checked="@productForm.TagIds.Contains(tag.Id)" @onchange="args => ToggleTag(tag.Id, args.Value)" />
                        @tag.Name
                    </label>
                }
            </div>

            <div class="khb-chip-panel">
                <h3>مشخصات کالا</h3>
                @foreach (var spec in lookups.SpecDefinitions)
                {
                    <div class="khb-spec-row">
                        <span>@spec.Name @(!string.IsNullOrWhiteSpace(spec.Unit) ? $"({spec.Unit})" : string.Empty)</span>
                        <input class="khb-input" value="@GetSpecValue(spec.Id)" @oninput="e => SetSpecValue(spec.Id, e.Value?.ToString())" />
                    </div>
                }
            </div>

            <div class="khb-actions">
                <button class="khb-btn" type="submit">ثبت محصول در سیستم لوکال</button>
                <button class="khb-btn khb-btn-soft" type="button" @onclick="ResetProductForm">فرم جدید</button>
            </div>
        </EditForm>
    </section>

    <section class="khb-card khb-card-wide">
        <div class="khb-section-title">
            <h2>محصولات ثبت‌شده</h2>
            <input class="khb-input khb-search" placeholder="جستجو..." @bind="search" @bind:event="oninput" />
        </div>
        <button class="khb-btn khb-btn-soft" @onclick="SearchProductsAsync">جستجو</button>
        <div class="khb-table-wrap">
            <table class="khb-table">
                <thead>
                    <tr>
                        <th>نام</th>
                        <th>دسته</th>
                        <th>برند</th>
                        <th>قیمت</th>
                        <AuthorizeView Roles="SuperAdmin,Admin,PricingManager" Context="authContext"><th>خرید</th></AuthorizeView>
                        <th>موجودی</th>
                        <th>وضعیت</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in products)
                    {
                        <tr>
                            <td>@row.Name<br /><small>@row.Sku</small></td>
                            <td>@row.CategoryName</td>
                            <td>@row.BrandName</td>
                            <td>@row.Price</td>
                            <AuthorizeView Roles="SuperAdmin,Admin,PricingManager" Context="authContext"><td>@row.PurchasePrice</td></AuthorizeView>
                            <td>@row.StockQuantity</td>
                            <td>@(row.IsAvailable ? "فعال" : "غیرفعال")</td>
                            <td><button class="khb-link" @onclick="() => EditProductAsync(row.Id)">ویرایش</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@code {
    private CatalogLookupsDto lookups = new([], [], [], [], []);
    private List<AdminProductListItemDto> products = [];
    private string? message;
    private string? search;
    private int? editingProductId;

    private BrandForm brandForm = new();
    private CommodityForm commodityForm = new();
    private TagForm tagForm = new();
    private SpecForm specForm = new();
    private ProductForm productForm = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        lookups = await CatalogClient.GetLookupsAsync() ?? new([], [], [], [], []);
        await SearchProductsAsync();
    }

    private async Task SearchProductsAsync() => products = (await CatalogClient.GetProductsAsync(search)).ToList();

    private async Task CreateBrandAsync()
    {
        var response = await CatalogClient.CreateBrandAsync(new BrandUpsertRequest { Name = brandForm.Name, Slug = brandForm.Slug, LogoUrl = brandForm.LogoUrl });
        await FinishSmallCreateAsync(response, () => brandForm = new());
    }

    private async Task CreateCommodityAsync()
    {
        var response = await CatalogClient.CreateCommodityAsync(new CommodityUpsertRequest { Name = commodityForm.Name, Slug = commodityForm.Slug, EnglishName = commodityForm.EnglishName, Description = commodityForm.Description });
        await FinishSmallCreateAsync(response, () => commodityForm = new());
    }

    private async Task CreateTagAsync()
    {
        var response = await CatalogClient.CreateTagAsync(new ProductTagUpsertRequest { Name = tagForm.Name, Slug = tagForm.Slug });
        await FinishSmallCreateAsync(response, () => tagForm = new());
    }

    private async Task CreateSpecAsync()
    {
        var response = await CatalogClient.CreateSpecDefinitionAsync(new SpecDefinitionUpsertRequest { Name = specForm.Name, Slug = specForm.Slug, Unit = specForm.Unit, SortOrder = specForm.SortOrder });
        await FinishSmallCreateAsync(response, () => specForm = new());
    }

    private async Task FinishSmallCreateAsync(HttpResponseMessage response, Action reset)
    {
        if (response.IsSuccessStatusCode)
        {
            reset();
            message = "ثبت انجام شد.";
            await LoadAsync();
        }
        else
        {
            message = await response.Content.ReadAsStringAsync();
        }
    }

    private async Task SaveProductAsync()
    {
        var request = productForm.ToRequest();
        var response = editingProductId.HasValue
            ? await CatalogClient.UpdateProductAsync(editingProductId.Value, request)
            : await CatalogClient.CreateProductAsync(request);

        if (response.IsSuccessStatusCode)
        {
            message = "محصول در سیستم لوکال ثبت شد. ارسال به سایت اصلی فقط بعد از فرآیند تایید انجام می‌شود.";
            ResetProductForm();
            await SearchProductsAsync();
        }
        else
        {
            message = await response.Content.ReadAsStringAsync();
        }
    }

    private async Task EditProductAsync(int id)
    {
        var details = await CatalogClient.GetProductAsync(id);
        if (details is null)
        {
            message = "محصول پیدا نشد.";
            return;
        }

        editingProductId = details.Id;
        productForm = ProductForm.From(details);
    }

    private void ResetProductForm()
    {
        editingProductId = null;
        productForm = new ProductForm();
    }

    private void ToggleTag(int tagId, object? value)
    {
        var isChecked = value is bool b && b;
        if (isChecked && !productForm.TagIds.Contains(tagId))
        {
            productForm.TagIds.Add(tagId);
        }
        else if (!isChecked)
        {
            productForm.TagIds.Remove(tagId);
        }
    }

    private string? GetSpecValue(int specId) => productForm.Specs.FirstOrDefault(x => x.SpecDefinitionId == specId)?.Value;

    private void SetSpecValue(int specId, string? value)
    {
        var current = productForm.Specs.FirstOrDefault(x => x.SpecDefinitionId == specId);
        if (string.IsNullOrWhiteSpace(value))
        {
            if (current is not null)
            {
                productForm.Specs.Remove(current);
            }
            return;
        }

        if (current is null)
        {
            productForm.Specs.Add(new SpecValueForm { SpecDefinitionId = specId, Value = value });
        }
        else
        {
            current.Value = value;
        }
    }

    private sealed class BrandForm { public string Name { get; set; } = string.Empty; public string? Slug { get; set; } public string? LogoUrl { get; set; } }
    private sealed class CommodityForm { public string Name { get; set; } = string.Empty; public string? Slug { get; set; } public string? EnglishName { get; set; } public string? Description { get; set; } }
    private sealed class TagForm { public string Name { get; set; } = string.Empty; public string? Slug { get; set; } }
    private sealed class SpecForm { public string Name { get; set; } = string.Empty; public string? Slug { get; set; } public string? Unit { get; set; } public int SortOrder { get; set; } }
    private sealed class SpecValueForm { public int SpecDefinitionId { get; set; } public string Value { get; set; } = string.Empty; }

    private sealed class ProductForm
    {
        public string Name { get; set; } = string.Empty;
        public string? Slug { get; set; }
        public string? Sku { get; set; }
        public string? Description { get; set; }
        public int CategoryId { get; set; }
        public int? BrandId { get; set; }
        public int? CommodityId { get; set; }
        public string? ImageUrl { get; set; }
        public decimal Price { get; set; }
        public decimal? OldPrice { get; set; }
        public decimal? PurchasePrice { get; set; }
        public int StockQuantity { get; set; }
        public int? MinStockAlertQuantity { get; set; }
        public bool IsAvailable { get; set; } = true;
        public long? WooCommerceProductId { get; set; }
        public List<int> TagIds { get; set; } = [];
        public List<SpecValueForm> Specs { get; set; } = [];

        public ProductUpsertRequest ToRequest() => new()
        {
            Name = Name,
            Slug = Slug,
            Sku = Sku,
            Description = Description,
            CategoryId = CategoryId,
            BrandId = BrandId,
            CommodityId = CommodityId,
            ImageUrl = ImageUrl,
            Price = Price,
            OldPrice = OldPrice,
            PurchasePrice = PurchasePrice,
            StockQuantity = StockQuantity,
            MinStockAlertQuantity = MinStockAlertQuantity,
            IsAvailable = IsAvailable,
            WooCommerceProductId = WooCommerceProductId,
            TagIds = TagIds,
            Specs = Specs.Select(x => new ProductSpecValueUpsertDto { SpecDefinitionId = x.SpecDefinitionId, Value = x.Value }).ToList()
        };

        public static ProductForm From(AdminProductDetailsDto details) => new()
        {
            Name = details.Name,
            Slug = details.Slug,
            Sku = details.Sku,
            Description = details.Description,
            CategoryId = details.CategoryId,
            BrandId = details.BrandId,
            CommodityId = details.CommodityId,
            ImageUrl = details.ImageUrl,
            Price = details.Price,
            OldPrice = details.OldPrice,
            PurchasePrice = details.PurchasePrice,
            StockQuantity = details.StockQuantity,
            MinStockAlertQuantity = details.MinStockAlertQuantity,
            IsAvailable = details.IsAvailable,
            WooCommerceProductId = details.WooCommerceProductId,
            TagIds = details.TagIds.ToList(),
            Specs = details.Specs.Select(x => new SpecValueForm { SpecDefinitionId = x.SpecDefinitionId, Value = x.Value }).ToList()
        };
    }
}

<style>
.khb-admin-shell{padding:24px;background:#f7f7f4;color:#1f2933;font-family:Tahoma,Arial,sans-serif}.khb-admin-header{display:flex;justify-content:space-between;gap:24px;align-items:center;margin-bottom:20px}.khb-admin-header h1{margin:6px 0 8px;font-size:28px}.khb-eyebrow{font-size:13px;color:#687076}.khb-grid{display:grid;gap:16px}.khb-grid-4{grid-template-columns:repeat(4,minmax(0,1fr))}.khb-card{background:#fff;border:1px solid #e6e2d8;border-radius:18px;padding:18px;box-shadow:0 10px 30px rgba(0,0,0,.04)}.khb-card h2{font-size:18px;margin:0 0 14px}.khb-card-wide{margin-top:18px}.khb-section-title{display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:16px}.khb-form-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px}.khb-col-span-2{grid-column:span 2}.khb-input{width:100%;border:1px solid #d6d3ca;border-radius:12px;padding:10px 12px;background:#fff;min-height:42px}.khb-textarea{min-height:90px}.khb-btn{border:0;border-radius:12px;background:#31572c;color:#fff;padding:10px 16px;margin-top:12px;cursor:pointer}.khb-btn-soft{background:#edf3ea;color:#31572c;border:1px solid #c9d8c4}.khb-link{border:0;background:transparent;color:#31572c;text-decoration:underline;cursor:pointer}.khb-alert{background:#fff7e6;border:1px solid #ffd68a;border-radius:14px;padding:12px 14px;margin-bottom:16px}.khb-chip-panel{border:1px dashed #d9d4c9;border-radius:14px;padding:12px;margin-top:14px}.khb-chip{display:inline-flex;gap:6px;align-items:center;background:#f4f1ea;border-radius:999px;padding:8px 12px;margin:4px}.khb-spec-row{display:grid;grid-template-columns:220px 1fr;gap:10px;align-items:center;margin-bottom:8px}.khb-actions{display:flex;gap:10px}.khb-table-wrap{overflow:auto}.khb-table{width:100%;border-collapse:collapse;margin-top:12px}.khb-table th,.khb-table td{border-bottom:1px solid #eee7dc;text-align:right;padding:10px}.khb-search{max-width:300px}@@media(max-width:1100px){.khb-grid-4,.khb-form-grid{grid-template-columns:1fr 1fr}.khb-col-span-2{grid-column:span 2}}@@media(max-width:700px){.khb-grid-4,.khb-form-grid{grid-template-columns:1fr}.khb-col-span-2{grid-column:span 1}.khb-admin-header,.khb-section-title{display:block}.khb-spec-row{grid-template-columns:1fr}}
</style>
