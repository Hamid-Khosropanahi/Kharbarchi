@using Kharbarchi.Shared.Security
@using Microsoft.AspNetCore.Components.Authorization

<nav class="@ResolvedNavClass" aria-label="@ResolvedAriaLabel" id="@ResolvedMenuId" dir="rtl">
    <ul class="@ResolvedMenuClass">
        <AuthorizeView Context="authContext">
            <Authorized>
                <li><NavLink href="/local-admin" Match="NavLinkMatch.All">داشبورد</NavLink></li>

                <AuthorizeView Roles="@KharbarchiRoles.SuperAdmins" Context="superAdminContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/users">کاربران و نقش‌ها</NavLink></li>
                        <li><NavLink href="/local-admin/sync-outbox">صف همگام‌سازی</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.CatalogWriters" Context="catalogContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/catalog">کاتالوگ</NavLink></li>
                        <li><NavLink href="/local-admin/woocommerce-import">ورود از ووکامرس</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.PriceProposers" Context="priceContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/pricing">قیمت‌گذاری</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.InventoryProposers" Context="inventoryContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/inventory">انبار</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.OrderViewersCsv" Context="orderContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/orders">سفارش‌ها</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.BarookPaymentOperatorsCsv" Context="barookContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/barook-payment">پرداخت باروک</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.PaymentOperatorsCsv" Context="accountingContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/accounting">حسابداری</NavLink></li>
                    </Authorized>
                </AuthorizeView>
            </Authorized>
            <NotAuthorized>
                <li><NavLink href="/login">ورود</NavLink></li>
            </NotAuthorized>
        </AuthorizeView>
    </ul>
</nav>

@code {
    // New clean parameters
    [Parameter] public string? NavClass { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? MenuId { get; set; }
    [Parameter] public string? MenuClass { get; set; }

    // Compatibility with the old shop header parameters.
    // These prevent runtime crashes such as: property matching the name 'Base_Classes' was not found.
    [Parameter] public string? Base_Classes { get; set; }
    [Parameter] public string? Aria_Label { get; set; }
    [Parameter] public string? Menu_ID { get; set; }
    [Parameter] public string? Menu_Class { get; set; }
    [Parameter] public string? Ul_Class { get; set; }
    [Parameter] public string? List_Class { get; set; }
    [Parameter] public string? Item_Class { get; set; }

    // Old menu values are intentionally ignored because the menu must now be role-based.
    [Parameter] public object? MenuItems { get; set; }
    // [Parameter] public object? Menu_Items { get; set; }
    [Parameter] public object? User_Menu { get; set; }

    // Any remaining unknown old attributes are accepted instead of throwing.
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolvedNavClass => FirstNotEmpty(NavClass, Base_Classes, GetAttr("Base_Classes"), "khb-main-nav");
    private string ResolvedAriaLabel => FirstNotEmpty(AriaLabel, Aria_Label, GetAttr("Aria_Label"), "منوی اصلی مدیریت");
    private string ResolvedMenuId => FirstNotEmpty(MenuId, Menu_ID, GetAttr("Menu_ID"), "khb-main-menu");
    private string ResolvedMenuClass => FirstNotEmpty(MenuClass, Menu_Class, Ul_Class, GetAttr("Menu_Class"), GetAttr("Ul_Class"), "khb-main-menu");

    private string? GetAttr(string key)
    {
        if (AdditionalAttributes is null)
        {
            return null;
        }

        return AdditionalAttributes.TryGetValue(key, out var value) ? value?.ToString() : null;
    }

    private static string FirstNotEmpty(params string?[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return string.Empty;
    }
}
