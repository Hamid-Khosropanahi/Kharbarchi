@page "/local-admin/woocommerce-import"
@attribute [Authorize(Roles = "SuperAdmin,Admin,CentralSyncAgent")]
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<section class="khb-hero">
    <span class="khb-eyebrow">WooCommerce → MySQL</span>
    <h1 class="khb-title">دریافت و ذخیره اطلاعات پایه فروشگاه</h1>
    <p class="khb-lead">
        تست Server یا WordPress Root ممکن است بدون Consumer Key موفق شود، اما Import محصولات، دسته‌ها و سفارش‌ها از WooCommerce wc/v3 حتماً به Consumer Key و Consumer Secret نیاز دارد. این صفحه مقادیر ذخیره‌شده در آزمایشگاه اتصال را خودکار می‌خواند.
    </p>
</section>

<section class="khb-grid">
    <div class="khb-card" style="grid-column: span 5;">
        <div class="khb-card-head"><h3>تنظیمات دریافت</h3><span class="khb-badge">Import</span></div>
        <div class="khb-form">
            <div class="khb-field full">
                <label>آدرس سایت ووکامرس</label>
                <input class="khb-input" @bind="Request.BaseUrl" placeholder="https://localhost:4433/Kharbarchi" />
            </div>
            <div class="khb-field full">
                <label>Consumer Key</label>
                <input class="khb-input" @bind="Request.ConsumerKey" placeholder="ck_..." autocomplete="off" />
            </div>
            <div class="khb-field full">
                <label>Consumer Secret</label>
                <input class="khb-input" type="password" @bind="Request.ConsumerSecret" placeholder="cs_..." autocomplete="off" />
            </div>
            <div class="khb-field">
                <label>تعداد محصولات</label>
                <input class="khb-input" type="number" @bind="Request.ProductTake" />
            </div>
            <div class="khb-field">
                <label>تعداد سفارش‌ها</label>
                <input class="khb-input" type="number" @bind="Request.OrderTake" />
            </div>
        </div>
        <div class="khb-actions">
            <button class="khb-btn khb-btn-ghost" disabled="@Busy" @onclick="SaveSettings">ذخیره موقت کلیدها</button>
            <button class="khb-btn khb-btn-ghost" disabled="@Busy" @onclick="TestServer">۱) تست Server داخلی</button>
            <button class="khb-btn khb-btn-soft" disabled="@Busy" @onclick="TestWoo">۲) تست ووکامرس</button>
            <button class="khb-btn khb-btn-primary" disabled="@Busy" @onclick="ImportData">۳) دریافت و ذخیره در MySQL</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(Status))
        {
            <div class="khb-status @(IsError ? "error" : "")" style="margin-top:16px">@Status</div>
        }
    </div>

    <div class="khb-card" style="grid-column: span 7;">
        <div class="khb-card-head"><h3>Raw Result / Error</h3><span class="khb-badge">Debug</span></div>
        <textarea class="khb-textarea" readonly @bind="RawResult"></textarea>
        <div class="khb-actions">
            <button class="khb-btn khb-btn-ghost" @onclick="Clear">پاک کردن خروجی</button>
            <a class="khb-btn khb-btn-soft" href="local-admin/woocommerce-settings">بازگشت به آزمایشگاه اتصال</a>
        </div>
    </div>
</section>

@code {
    private readonly WooLabRequest Request = new()
    {
        BaseUrl = "https://localhost:4433/Kharbarchi",
        Endpoint = "wp-json/wc/v3/products?per_page=5",
        ProductTake = 50,
        OrderTake = 50,
        TimeoutSeconds = 60
    };

    private bool Busy;
    private bool IsError;
    private string? Status;
    private string RawResult = "کلیدهای ووکامرس را وارد کن یا ابتدا از صفحه آزمایشگاه اتصال ذخیره کن.";

    private HttpClient Api => HttpClientFactory.CreateClient("KharbarchiAPI");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadSettings();
        StateHasChanged();
    }

    private async Task SaveSettings()
    {
        await SaveSettingsToBrowser();
        IsError = false;
        Status = "BaseUrl و کلیدهای ووکامرس در همین مرورگر ذخیره شد.";
    }

    private async Task TestServer()
    {
        await Run(async () =>
        {
            await SaveSettingsToBrowser();
            return Pretty(await Api.GetStringAsync("api/admin/woo-lab/config-state"));
        }, "اتصال Client به Server داخلی برقرار است.");
    }

    private async Task TestWoo()
    {
        await Run(async () =>
        {
            await SaveSettingsToBrowser();
            var response = await Api.PostAsJsonAsync("api/admin/woo-lab/test", Request);
            return await ReadResponse(response);
        }, "پاسخ تست ووکامرس دریافت شد.");
    }

    private async Task ImportData()
    {
        await Run(async () =>
        {
            await SaveSettingsToBrowser();
            var response = await Api.PostAsJsonAsync("api/admin/woo-lab/import-default", Request);
            return await ReadResponse(response);
        }, "فرآیند دریافت و ذخیره اجرا شد. خروجی خام را بررسی کنید.");
    }

    private async Task<string> ReadResponse(HttpResponseMessage response)
    {
        var text = await response.Content.ReadAsStringAsync();
        if (!response.IsSuccessStatusCode)
        {
            throw new InvalidOperationException($"HTTP {(int)response.StatusCode} {response.ReasonPhrase}\n{text}");
        }
        return Pretty(text);
    }

    private async Task Run(Func<Task<string>> action, string okMessage)
    {
        Busy = true;
        IsError = false;
        Status = "در حال انجام عملیات...";
        RawResult = string.Empty;
        try
        {
            RawResult = await action();
            Status = okMessage;
        }
        catch (Exception ex)
        {
            IsError = true;
            Status = "خطا در ارتباط یا پردازش. متن کامل در خروجی خام آمده است.";
            RawResult = ex.ToString();
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task LoadSettings()
    {
        Request.BaseUrl = await GetStorage("khbWooBaseUrl", Request.BaseUrl);
        Request.ConsumerKey = await GetStorage("khbWooConsumerKey", Request.ConsumerKey);
        Request.ConsumerSecret = await GetStorage("khbWooConsumerSecret", Request.ConsumerSecret);
    }

    private async Task SaveSettingsToBrowser()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "khbWooBaseUrl", Request.BaseUrl ?? string.Empty);
        await JS.InvokeVoidAsync("localStorage.setItem", "khbWooConsumerKey", Request.ConsumerKey ?? string.Empty);
        await JS.InvokeVoidAsync("localStorage.setItem", "khbWooConsumerSecret", Request.ConsumerSecret ?? string.Empty);
    }

    private async Task<string> GetStorage(string key, string fallback)
    {
        var value = await JS.InvokeAsync<string?>("localStorage.getItem", key);
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    private static string Pretty(string text)
    {
        try
        {
            using var doc = JsonDocument.Parse(text);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return text;
        }
    }

    private void Clear()
    {
        RawResult = string.Empty;
        Status = null;
        IsError = false;
    }

    private sealed class WooLabRequest
    {
        public string BaseUrl { get; set; } = string.Empty;
        public string ConsumerKey { get; set; } = string.Empty;
        public string ConsumerSecret { get; set; } = string.Empty;
        public string Endpoint { get; set; } = string.Empty;
        public int ProductTake { get; set; } = 50;
        public int OrderTake { get; set; } = 50;
        public int TimeoutSeconds { get; set; } = 60;
    }
}
