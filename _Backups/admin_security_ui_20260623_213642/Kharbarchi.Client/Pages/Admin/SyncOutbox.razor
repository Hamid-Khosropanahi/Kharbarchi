@page "/local-admin/sync-outbox"
@attribute [Authorize(Roles = "SuperAdmin,Admin,CentralSyncAgent")]
@using Kharbarchi.Client.Services
@using Kharbarchi.Shared.Contracts
@using Kharbarchi.Shared.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@inject SyncOutboxClient OutboxClient

<PageTitle>صف ارسال مرکزی</PageTitle>

<div class="khb-workflow" dir="rtl">
    <header class="khb-admin-header">
        <div>
            <span class="khb-eyebrow">Outbox امن</span>
            <h1>صف تغییرات تاییدشده برای ارسال به سایت اصلی</h1>
            <p>سیستم مرکزی پس از Authorization پیام‌های Pending را claim می‌کند و بعد از بروزرسانی WooCommerce وضعیت را Sent می‌کند.</p>
        </div>
        <button class="khb-btn khb-btn-soft" @onclick="LoadAsync">بروزرسانی</button>
    </header>

    <section class="khb-card">
        <table class="khb-table">
            <thead>
                <tr><th>شناسه</th><th>رویداد</th><th>نوع</th><th>وضعیت</th><th>منبع</th><th>کاربر</th><th>تاریخ</th><th>خطا</th></tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr>
                        <td>@row.Id</td>
                        <td>@row.EventType</td>
                        <td>@row.AggregateType / @row.AggregateId</td>
                        <td>@row.Status</td>
                        <td>@row.SourceWorkflow</td>
                        <td>@row.QueuedByUserName</td>
                        <td>@row.CreatedAtUtc.ToLocalTime()</td>
                        <td>@row.LastError</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
</div>

@code {
    private List<SyncOutboxDto> rows = [];
    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync() => rows = (await OutboxClient.GetOutboxAsync()).ToList();
}

<style>
.khb-workflow{padding:24px;background:#f7f7f4;color:#1f2933;font-family:Tahoma,Arial,sans-serif}.khb-admin-header{display:flex;justify-content:space-between;gap:24px;align-items:center;margin-bottom:20px}.khb-card{background:#fff;border:1px solid #e6e2d8;border-radius:18px;padding:18px;box-shadow:0 10px 30px rgba(0,0,0,.04)}.khb-eyebrow{font-size:13px;color:#687076}.khb-btn{border:0;border-radius:12px;background:#31572c;color:#fff;padding:10px 16px;margin-top:12px;cursor:pointer}.khb-btn-soft{background:#edf3ea;color:#31572c;border:1px solid #c9d8c4}.khb-table{width:100%;border-collapse:collapse;margin-top:12px}.khb-table th,.khb-table td{border-bottom:1px solid #eee7dc;text-align:right;padding:10px}
</style>
