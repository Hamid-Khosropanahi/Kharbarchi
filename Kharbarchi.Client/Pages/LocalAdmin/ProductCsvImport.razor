    private async Task LoadWorkflowTab()
    {
        await Run(async () =>
        {
            var url =
                $"api/product-csv/workflow-table?kind={Uri.EscapeDataString(activeWorkflowTab)}&page={workflowPage}&pageSize={workflowPageSize}";

            var result = await Api.GetFromJsonAsync<WorkflowTableResult>(url);

            workflowRows = result?.Items ?? new();
            workflowTotalRows = result?.Total ?? 0;

            workflowColumns = workflowRows
                .SelectMany(x => x.Keys)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
        }, showOk: false);
    }

    private async Task PrevWorkflowPage()
    {
        if (workflowPage <= 1)
        {
            return;
        }

        workflowPage--;
        await LoadWorkflowTab();
    }

    private async Task NextWorkflowPage()
    {
        if (workflowPage >= WorkflowTotalPages)
        {
            return;
        }

        workflowPage++;
        await LoadWorkflowTab();
    }

