    private async Task<bool> TestWooConnection(bool showSuccessMessage)
    {
        if (selectedProfileId <= 0)
        {
            wooConnectionMessage = "ابتدا یک پروفایل WooCommerce انتخاب کنید.";
            message = wooConnectionMessage;
            return false;
        }

        using var response = await Api.PostAsync(
            $"api/admin/woocommerce-profiles/{selectedProfileId}/test",
            null,
            pageCancellation.Token);
        var result = await response.Content.ReadFromJsonAsync<WooConnectionProfileTestResultDto>(
            cancellationToken: pageCancellation.Token);

        if (!response.IsSuccessStatusCode || result?.Success != true)
        {
            var detail = result?.Message ?? await response.Content.ReadAsStringAsync();
            wooConnectionMessage = "اتصال WooCommerce برقرار نشد: " + detail;
            message = wooConnectionMessage;
            return false;
        }

        wooConnectionMessage = $"اتصال WooCommerce موفق بود. Status={result.StatusCode}، زمان پاسخ={result.ElapsedMilliseconds} ms";
        if (showSuccessMessage)
        {
            message = wooConnectionMessage;
        }

        return true;
    }

