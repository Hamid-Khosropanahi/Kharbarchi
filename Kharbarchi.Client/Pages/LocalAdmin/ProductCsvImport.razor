    private async Task RunWooProductBatchLoop()
    {
        await RefreshWooProgress();
        var guard = 0;

        while (guard++ < 10000)
        {
            if (wooProgress.Total > 0 && wooProgress.Pending <= 0)
            {
                break;
            }

            message = $"ارسال batch شماره {guard}؛ باقی‌مانده: {wooProgress.Pending} از {wooProgress.Total}";
            await InvokeAsync(StateHasChanged);

            using var response = await Api.PostAsync($"api/product-csv/woocommerce/sync-products-batch?take={wooBatchTake}&skipConnectionTest=true", null);
            var batch = await ReadBatchResponse(response);

            wooProgress = new WooSyncProgress
            {
                Total = batch.Total,
                Synced = batch.Synced,
                Failed = batch.Failed,
                Pending = batch.Pending,
                Percent = batch.Percent
            };

            await InvokeAsync(StateHasChanged);

            if (batch.ProductsSynced == 0 && batch.ProductsFailed == 0)
            {
                break;
            }
        }

        message = $"ارسال WooCommerce تمام شد. ارسال‌شده: {wooProgress.Synced}، خطادار: {wooProgress.Failed}، در انتظار: {wooProgress.Pending}";
        activeWorkflowTab = "queue";
        workflowPage = 1;
        await LoadWorkflowTab();
    }

    private async Task RefreshWooProgress()
    {
        var result = await Api.GetFromJsonAsync<WooSyncProgress>("api/product-csv/woocommerce/sync-progress");
        wooProgress = result ?? new WooSyncProgress();
    }

    private async Task<string> RunTrackedOperationAsync(
        string type,
        Func<Guid, Task<HttpResponseMessage>> operation)
    {
        using var startResponse = await Api.PostAsync(
            $"api/product-csv/jobs/{Uri.EscapeDataString(type)}/start",
            null,
            pageCancellation.Token);
        await EnsureSuccess(startResponse);
        activeJob = await startResponse.Content.ReadFromJsonAsync<WorkflowJobDto>(
            cancellationToken: pageCancellation.Token)
            ?? throw new InvalidOperationException("Server did not return a JobId.");
        jobLogs.Clear();
        await InvokeAsync(StateHasChanged);

        var operationTask = operation(activeJob.JobId);
        while (!operationTask.IsCompleted)
        {
            await RefreshActiveJob();
            await Task.Delay(600, pageCancellation.Token);
        }

        using var response = await operationTask;
        var result = await ReadResponse(response);
        await RefreshActiveJob();
        return result;
    }

    private async Task RefreshActiveJob()
    {
        if (activeJob is null)
        {
            return;
        }

        activeJob = await Api.GetFromJsonAsync<WorkflowJobDto>(
            $"api/product-csv/jobs/{activeJob.JobId}",
            pageCancellation.Token) ?? activeJob;
        jobLogs = await Api.GetFromJsonAsync<List<WorkflowJobLogDto>>(
            $"api/product-csv/jobs/{activeJob.JobId}/logs?take=200",
            pageCancellation.Token) ?? new();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadProfiles()
    {
        wooProfiles = await Api.GetFromJsonAsync<List<WooConnectionProfileDto>>(
            "api/admin/woocommerce-profiles",
            pageCancellation.Token) ?? new();
        var environmentProfile = wooProfiles.FirstOrDefault(x => x.IsActive)
            ?? wooProfiles.FirstOrDefault();
        if (environmentProfile is not null)
        {
            hostEnvironmentType = environmentProfile.EnvironmentType;
        }

        var selected = wooProfiles.FirstOrDefault(
                x => x.Id == selectedProfileId && x.EnvironmentType == hostEnvironmentType)
            ?? wooProfiles.FirstOrDefault(x => x.IsActive && x.EnvironmentType == hostEnvironmentType)
            ?? wooProfiles.FirstOrDefault(x => x.EnvironmentType == hostEnvironmentType);
        if (selected is not null)
        {
            ApplyProfile(selected);
        }
        else
        {
            NewProfile();
        }
    }

    private void SelectProfile(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var id))
        {
            id = 0;
        }

        var profile = wooProfiles.FirstOrDefault(x => x.Id == id);
        if (profile is null || profile.EnvironmentType != hostEnvironmentType)
        {
            NewProfile();
            return;
        }

        ApplyProfile(profile);
    }

    private void ApplyProfile(WooConnectionProfileDto profile)
    {
        selectedProfileId = profile.Id;
        selectedProfileKeyMask = profile.ConsumerKeyMasked;
        profileEditor = new WooConnectionProfileUpsertRequest
        {
            Id = profile.Id,
            ProfileName = profile.ProfileName,
            EnvironmentType = hostEnvironmentType,
            BaseUrl = IsProductionEnvironment ? productionShopUrl : profile.BaseUrl,
            ConsumerKey = string.Empty,
            ConsumerSecret = string.Empty,
            ApiVersion = profile.ApiVersion,
            VerifySsl = profile.VerifySsl,
            TimeoutSeconds = profile.TimeoutSeconds,
            IsActive = profile.IsActive
        };
    }

    private void NewProfile()
    {
        selectedProfileId = 0;
        selectedProfileKeyMask = string.Empty;
        profileEditor = NewProfileEditor();
    }

