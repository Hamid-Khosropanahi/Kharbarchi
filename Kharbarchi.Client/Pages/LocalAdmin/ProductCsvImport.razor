@page "/local-admin/product-csv-import"
@attribute [Authorize(Policy = "ProductImportWrite")]
@implements IAsyncDisposable
@using System.Net.Http.Json
@using Kharbarchi.Shared.Contracts.ProductWorkflow
@using Kharbarchi.Shared.Contracts.WooCommerce
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@inject IHttpClientFactory ClientFactory

<PageTitle>ورود و کنترل CSV محصولات</PageTitle>

<div class="khb-product-workflow" dir="rtl">
    <section class="khb-hero khb-card">
        <div>
            <p class="khb-kicker">مرکز کنترل محصول خواربارچی</p>
            <h1>ورود CSV، ویرایش داده خام، ساخت محصول نهایی و صف ووکامرس</h1>
            <p>
                این صفحه همان فایل CSV را وارد می‌کند، قبل از پردازش اجازه ویرایش می‌دهد، سپس جداول KHB را با روش upsert و بدون پاک‌سازی می‌سازد. خروجی نهایی همیشه تومان است.
            </p>
        </div>
        <div class="khb-steps">
            <span class="active">1 ورود CSV</span>
            <span>2 ویرایش Source</span>
            <span>3 ساخت جداول اصلی</span>
            <span>4 تایید و ارسال WooCommerce</span>
        </div>
    </section>

    <section class="khb-card khb-control-panel">
        <div class="khb-toolbar">
            <div>
                <h2>پروفایل اتصال WooCommerce</h2>
                <p class="khb-muted">کلیدها فقط در سرور نگهداری می‌شوند. Secret در مرورگر یا localStorage ذخیره نمی‌شود.</p>
            </div>
            <button class="khb-btn" @onclick="NewProfile" disabled="@busy">پروفایل جدید</button>
        </div>

        <div class="khb-inline-controls">
            <select value="@selectedProfileId" @onchange="SelectProfile" disabled="@busy">
                <option value="0">انتخاب پروفایل...</option>
                @foreach (var profile in wooProfiles.Where(x => x.EnvironmentType == hostEnvironmentType))
                {
                    <option value="@profile.Id">@profile.ProfileName - @profile.EnvironmentType @(profile.IsActive ? "(فعال)" : "")</option>
                }
            </select>
            <button class="khb-btn" @onclick="TestWooConnectionFromButton" disabled="@(busy || selectedProfileId <= 0)">تست اتصال</button>
        </div>

        <div class="khb-inline-fields">
            <label>نام پروفایل<input @bind="profileEditor.ProfileName" /></label>
            <label>
                محیط
                <select @bind="profileEditor.EnvironmentType" disabled>
                    <option value="@hostEnvironmentType">@hostEnvironmentType</option>
                </select>
            </label>
            <label>BaseUrl<input class="ltr" @bind="profileEditor.BaseUrl" readonly="@IsProductionEnvironment" /></label>
            <label>Consumer Key<input class="ltr" @bind="profileEditor.ConsumerKey" placeholder="@selectedProfileKeyMask" autocomplete="off" /></label>
            <label>Consumer Secret<input class="ltr" type="password" @bind="profileEditor.ConsumerSecret" placeholder="برای حفظ Secret فعلی خالی بگذارید" autocomplete="new-password" /></label>
            <label>API Version<input class="ltr" @bind="profileEditor.ApiVersion" /></label>
            <label>Timeout<input type="number" min="5" max="180" @bind="profileEditor.TimeoutSeconds" /></label>
        </div>
        <label class="khb-check-row">
            <input type="checkbox" @bind="profileEditor.VerifySsl" disabled="@(profileEditor.EnvironmentType == "Production")" />
            <span>بررسی گواهی SSL؛ برای Production همیشه فعال است.</span>
        </label>
        <label class="khb-check-row"><input type="checkbox" @bind="profileEditor.IsActive" /><span>پروفایل فعال این محیط</span></label>
        <button class="khb-btn primary" @onclick="SaveProfile" disabled="@busy">ذخیره پروفایل</button>
    </section>

    <section class="khb-card khb-control-panel">
        <label>
            نام جدول منبع
            <input @bind="tableName" readonly />
        </label>

        <div class="khb-warning">
            طبق قوانین پروژه، import و پردازش هیچ جدول خروجی را پاک نمی‌کند. همه عملیات این صفحه upsert و غیرمخرب است.
        </div>

        <label>
            واحد قیمت‌های فایل/جدول هنگام پردازش
            <select @bind="priceUnit">
                <option value="rial">ریال - هنگام پردازش تقسیم بر ۱۰ شود</option>
                <option value="toman">تومان - بدون تبدیل استفاده شود</option>
            </select>
            <small>برای کارتن وزنی، قیمت ورودی قیمت کیلویی است. برای کارتن بسته‌ای، قیمت ورودی قیمت هر بسته است. هزینه بسته‌بندی فقط meta/گزارش است و در محاسبه فروش کارتنی لحاظ نمی‌شود.</small>
        </label>

        <div class="khb-price-status">
            <strong>وضعیت پردازش:</strong>
            @if (priceUnit == "rial")
            {
                <span>ورودی ریال است و هنگام پردازش به تومان تقسیم بر ۱۰ می‌شود.</span>
            }
            else
            {
                <span>ورودی تومان است و بدون تبدیل استفاده می‌شود.</span>
            }
        </div>

        <label>
            فایل CSV UTF-8
            <InputFile OnChange="OnFileSelected" accept=".csv" />
            @if (selectedFile is not null)
            {
                <small>@selectedFile.Name - @(selectedFile.Size / 1024) KB</small>
            }
        </label>

        <div class="khb-actions">
            <button class="khb-btn primary" @onclick="ImportCsv" disabled="@busy">ورود CSV به MySQL</button>
            <button class="khb-btn" @onclick="LoadSourceRows" disabled="@busy">نمایش جدول واردشده</button>
            <button class="khb-btn accent" @onclick="ProcessTable" disabled="@busy">ساخت جداول اصلی</button>
            <button class="khb-btn" @onclick="LoadProducts" disabled="@busy">نمایش محصولات نهایی</button>
            <button class="khb-btn" @onclick="TestWooConnectionFromButton" disabled="@busy">تست اتصال WooCommerce</button>
            <label class="khb-batch-size">
                اندازه batch ارسال
                <select @bind="wooBatchTake" disabled="@busy">
                    <option value="1">1</option>
                    <option value="5">5</option>
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
            </label>
            <button class="khb-btn primary" @onclick="SyncWooCommerceAll" disabled="@busy">تست + ارسال مرحله‌ای همه</button>
            <button class="khb-btn" @onclick="SyncWooCommerceProducts" disabled="@busy">تست + ارسال مرحله‌ای محصولات</button>
        </div>
    </section>

    <section class="khb-card khb-woo-progress-card">
        <div class="khb-toolbar">
            <div>
                <h2>وضعیت عملیات Import / Process / Sync</h2>
                <p class="khb-muted">شناسه عملیات: @(activeJob?.JobId.ToString() ?? "-")</p>
                @if (!string.IsNullOrWhiteSpace(wooConnectionMessage))
                {
                    <p class="khb-muted">@wooConnectionMessage</p>
                }
            </div>
            <button class="khb-btn" @onclick="RefreshActiveJob" disabled="@(activeJob is null)">به‌روزرسانی پیشرفت</button>
        </div>
        <div class="khb-sync-grid">
            <article><span>مرحله</span><strong>@(activeJob?.CurrentStep ?? "-")</strong></article>
            <article><span>کل</span><strong>@(activeJob?.TotalItems ?? 0)</strong></article>
            <article><span>پردازش‌شده</span><strong>@(activeJob?.ProcessedItems ?? 0)</strong></article>
            <article><span>موفق</span><strong>@(activeJob?.SuccessCount ?? 0)</strong></article>
            <article><span>خطا</span><strong>@(activeJob?.ErrorCount ?? 0)</strong></article>
            <article><span>Draft</span><strong>@(activeJob?.DraftCount ?? 0)</strong></article>
            <article><span>ردشده</span><strong>@(activeJob?.SkippedCount ?? 0)</strong></article>
            <article><span>در انتظار</span><strong>@(activeJob?.PendingCount ?? 0)</strong></article>
            <article><span>درصد</span><strong>@(activeJob?.ProgressPercent ?? 0)%</strong></article>
        </div>
        <div class="khb-progress-line" aria-label="Workflow job progress">
            <span style="width:@(Math.Clamp(activeJob?.ProgressPercent ?? 0, 0, 100))%"></span>
        </div>
        @if (!string.IsNullOrWhiteSpace(activeJob?.Message))
        {
            <p class="khb-muted">@activeJob.Message</p>
        }

        @if (jobLogs.Count > 0)
        {
            <div class="khb-table-wrap">
                <table>
                    <thead><tr><th>زمان</th><th>مرحله</th><th>نوع</th><th>SKU</th><th>وضعیت</th><th>پیام</th><th>HTTP</th></tr></thead>
                    <tbody>
                        @foreach (var log in jobLogs)
                        {
                            <tr>
                                <td class="ltr">@log.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@log.StepName</td>
                                <td>@log.EntityType</td>
                                <td class="ltr">@log.Sku</td>
                                <td>@log.Status</td>
                                <td>@log.Message</td>
                                <td>@log.ResponseCode</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <section class="khb-card khb-message">
            <pre>@message</pre>
        </section>
    }

    <section class="khb-card">
        <div class="khb-toolbar">
            <div>
                <h2>جدول واردشده از CSV قبل از ساخت محصول</h2>
                <p class="khb-muted">اینجا داده خام را اصلاح کن؛ سپس «ساخت جداول اصلی» را بزن.</p>
                <p class="khb-muted">تعداد ردیف‌ها: @totalSourceRows</p>

                <div class="khb-price-unit-banner">
                    <strong>واحد قیمت‌های این جدول:</strong>
                    <span>@SourcePriceUnitText</span>
                </div>
            </div>
            <div class="khb-inline-controls">
                <input placeholder="جستجو در Source..." @bind="sourceSearch" @bind:event="oninput" />
                <select @bind="sourcePageSize">
                    <option value="20">20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                </select>
                <button class="khb-btn" @onclick="SearchSourceRows" disabled="@busy">جستجو</button>
            </div>
        </div>
        <section class="khb-card">
            <div class="khb-workflow-tabs">
                <button class="khb-btn @(activeWorkflowTab == "source" ? "primary" : "")" @onclick="@(() => SelectWorkflowTab("source"))">Source</button>
                <button class="khb-btn @(activeWorkflowTab == "category" ? "primary" : "")" @onclick="@(() => SelectWorkflowTab("category"))">Categories</button>
                <button class="khb-btn @(activeWorkflowTab == "commodity" ? "primary" : "")" @onclick="@(() => SelectWorkflowTab("commodity"))">Commodities</button>
                <button class="khb-btn @(activeWorkflowTab == "package" ? "primary" : "")" @onclick="@(() => SelectWorkflowTab("package"))">Packages</button>
                <button class="khb-btn @(activeWorkflowTab == "product" ? "primary" : "")" @onclick="@(() => SelectWorkflowTab("product"))">Final Products</button>
                <button class="khb-btn @(activeWorkflowTab == "queue" ? "primary" : "")" @onclick="@(() => SelectWorkflowTab("queue"))">Woo Queue</button>
            </div>

            <div class="khb-toolbar">
                <div>
                    <h2>@WorkflowTabTitle</h2>
                    <p class="khb-muted">Total: @workflowTotalRows</p>
                </div>
                <div class="khb-inline-controls">
                    <select @bind="workflowPageSize">
                        <option value="20">20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                        <option value="200">200</option>
                    </select>
                    <button class="khb-btn" @onclick="LoadWorkflowTab" disabled="@busy">Refresh</button>
                </div>
            </div>

            <div class="khb-table-wrap">
                <table class="khb-table khb-resizable-table">
                    <thead>
                        <tr>
                            @foreach (var column in workflowColumns)
                            {
                                <th class="khb-resize-col">@column</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in workflowRows)
                        {
                            <tr>
                                @foreach (var column in workflowColumns)
                                {
                                    <td class="ltr">@GetWorkflowCell(row, column)</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="khb-pagination">
                <button class="khb-btn" @onclick="PrevWorkflowPage" disabled="@(busy || workflowPage <= 1)">Prev</button>
                <span>Page @(workflowPage) / @WorkflowTotalPages</span>
                <button class="khb-btn" @onclick="NextWorkflowPage" disabled="@(busy || workflowPage >= WorkflowTotalPages)">Next</button>
            </div>
        </section>
        <div class="khb-table-wrap tall">
            <table class="khb-table khb-resizable-table source-table">
                <thead>
                    <tr>
                        <th class="khb-resize-col">ذخیره</th>
                        <th class="khb-resize-col">ID</th>
                        <th class="khb-resize-col">نام فارسی</th>
                        <th class="khb-resize-col">نام انگلیسی</th>
                        <th class="khb-resize-col">کالای اصلی</th>
                        <th class="khb-resize-col">En_Taxonomic</th>
                        <th class="khb-resize-col">برند</th>
                        <th class="khb-resize-col">Brand_En</th>
                        <th class="khb-resize-col">Package</th>
                        <th class="khb-resize-col">وزن kg</th>
                        <th class="khb-resize-col">تعداد در کارتن</th>
                        <th class="khb-resize-col">بسته‌بندی هر بسته / واحد انتخابی</th>
                        <th class="khb-resize-col">قیمت نقد کیلویی / واحد انتخابی</th>
                        <th class="khb-resize-col">قیمت شرایطی کیلویی / واحد انتخابی</th>
                        <th class="khb-resize-col">Slug پیشنهادی</th>
                        <th class="khb-resize-col">SKU دستی</th>
                        <th class="khb-resize-col">وضعیت</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in sourceRows)
                    {
                        <tr>
                            <td><button class="khb-btn tiny primary" @onclick="() => SaveSourceRow(row)" disabled="@busy">ذخیره</button></td>
                            <td>@row.Id</td>
                            <td><input @bind="row.ProductName" /></td>
                            <td><input class="ltr" @bind="row.ProductEnglishName" /></td>
                            <td><input @bind="row.MainProductName" /></td>
                            <td><input class="ltr" @bind="row.CategorySlug" /></td>
                            <td><input @bind="row.BrandName" /></td>
                            <td><input class="ltr" @bind="row.BrandEnglishName" /></td>
                            <td><input @bind="row.PackageName" /></td>
                            <td><input class="num" type="number" step="0.001" @bind="row.UnitWeight" /></td>
                            <td><input class="num" type="number" @bind="row.CartonQuantity" /></td>
                            <td>
                                <input class="num money-input"
                                       type="text"
                                       inputmode="numeric"
                                       value="@FormatWholeNumber(row.PackagingPricePerPack)"
                                       @onchange="e => row.PackagingPricePerPack = ParseWholeNumber(e.Value)" />
                            </td>
                            <td>
                                <input class="num money-input"
                                       type="text"
                                       inputmode="numeric"
                                       value="@FormatWholeNumber(row.KgCashPrice)"
                                       @onchange="e => row.KgCashPrice = ParseWholeNumber(e.Value)" />
                            </td>

                            <td>
                                <input class="num money-input"
                                       type="text"
                                       inputmode="numeric"
                                       value="@FormatWholeNumber(row.KgCreditPrice)"
                                       @onchange="e => row.KgCreditPrice = ParseWholeNumber(e.Value)" />
                            </td>
                            <td><input class="ltr" @bind="row.ProductSlug" /></td>
                            <td><input class="ltr" @bind="row.Sku" /></td>
                            <td>
                                <select @bind="row.Status">
                                    <option value="publish">publish</option>
                                    <option value="draft">draft</option>
                                </select>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="khb-pagination">
            <button class="khb-btn" @onclick="PrevSourcePage" disabled="@(busy || sourcePage <= 1)">قبلی</button>
            <span>صفحه @(sourcePage) از @SourceTotalPages</span>
            <button class="khb-btn" @onclick="NextSourcePage" disabled="@(busy || sourcePage >= SourceTotalPages)">بعدی</button>
        </div>
    </section>

    <section class="khb-card">
        <div class="khb-toolbar">
            <div>
                <h2>محصولات نهایی قابل فروش</h2>
                <p class="khb-muted">تعداد کل: @totalProducts</p>

                <div class="khb-price-unit-banner final">
                    <strong>واحد قیمت‌های محصول نهایی:</strong>
                    <span>تومان</span>
                </div>
            </div>
            <div class="khb-inline-controls">
                <input placeholder="جستجو در محصولات..." @bind="productSearch" @bind:event="oninput" />
                <select @bind="productPageSize">
                    <option value="20">20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                    <option value="500">500</option>
                </select>
                <button class="khb-btn" @onclick="SearchProducts" disabled="@busy">جستجو</button>
            </div>
        </div>

        <div class="khb-table-wrap">
            <table class="khb-table khb-resizable-table final-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>محصول اصلی</th>
                        <th>نام محصول</th>
                        <th>SKU</th>
                        <th>Slug</th>
                        <th>بسته‌بندی</th>
                        <th>تعداد کارتن</th>
                        <th>قیمت پایه نقد / تومان</th>
                        <th>قیمت پایه شرایطی / تومان</th>
                        <th>هزینه بسته‌بندی اطلاعاتی / تومان</th>
                        <th>قیمت نقد نهایی / تومان</th>
                        <th>قیمت شرایطی نهایی / تومان</th>
                        <th>وضعیت</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in products)
                    {
                        <tr @ondblclick="() => ShowDetails(item)">
                            <td>@item.Id</td>
                            <td>@item.MainProductName</td>
                            <td>@item.ProductName</td>
                            <td class="ltr">@item.Sku</td>
                            <td class="ltr">@item.ProductSlug</td>
                            <td>@item.PackageName</td>
                            <td>@item.CartonQuantity</td>
                            <td>@FormatMoney(item.KgPriceCash)</td>
                            <td>@FormatMoney(item.KgPriceInstallment)</td>
                            <td>@FormatMoney(item.PackagingPricePerPack)</td>
                            <td>@FormatMoney(item.SalePriceCash)</td>
                            <td>@FormatMoney(item.SalePriceInstallment)</td>
                            <td>@item.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="khb-pagination">
            <button class="khb-btn" @onclick="PrevProductPage" disabled="@(busy || productPage <= 1)">قبلی</button>
            <span>صفحه @(productPage) از @ProductTotalPages</span>
            <button class="khb-btn" @onclick="NextProductPage" disabled="@(busy || productPage >= ProductTotalPages)">بعدی</button>
        </div>
    </section>

    @if (selectedProduct is not null)
    {
        <section class="khb-card khb-details">
            <div class="khb-toolbar">
                <h2>مشخصات کامل محصول</h2>
                <button class="khb-btn" @onclick="() => selectedProduct = null">بستن</button>
            </div>
            <pre>@System.Text.Json.JsonSerializer.Serialize(selectedProduct, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>
        </section>
    }
</div>



@code
{
    private string tableName = "all_product_with_process";
    private IBrowserFile? selectedFile;
    private const bool truncateBeforeImport = false;
    private const bool clearGeneratedBeforeProcess = false;
    private string priceUnit = "rial";
    private bool busy;
    private string? message;
    private string? wooConnectionMessage;
    private int wooBatchTake = 10;
    private WooSyncProgress wooProgress = new();
    private readonly CancellationTokenSource pageCancellation = new();
    private List<WooConnectionProfileDto> wooProfiles = new();
    private WooConnectionProfileUpsertRequest profileEditor = new();
    private int selectedProfileId;
    private string selectedProfileKeyMask = string.Empty;
    private const string productionShopUrl = "https://www.Kharbarchi.ir/";
    private const string localShopUrl = "https://localhost:4433/Kharbarchi";
    private string hostEnvironmentType = "Local";
    private bool IsProductionEnvironment => hostEnvironmentType == "Production";
    private WorkflowJobDto? activeJob;
    private List<WorkflowJobLogDto> jobLogs = new();

    private int sourcePage = 1;
    private int sourcePageSize = 50;
    private long totalSourceRows;
    private string? sourceSearch;
    private List<SourceRow> sourceRows = new();

    private int productPage = 1;
    private int productPageSize = 50;
    private long totalProducts;
    private string? productSearch;
    private List<SaleProductRow> products = new();
    private SaleProductRow? selectedProduct;

    private int SourceTotalPages => Math.Max(1, (int)Math.Ceiling(totalSourceRows / (double)sourcePageSize));
    private int ProductTotalPages => Math.Max(1, (int)Math.Ceiling(totalProducts / (double)productPageSize));
    private HttpClient Api => ClientFactory.CreateClient("KharbarchiAPI");

    protected override async Task OnInitializedAsync()
    {
        await LoadProfiles();
        activeJob = await Api.GetFromJsonAsync<WorkflowJobDto?>("api/product-csv/jobs/latest", pageCancellation.Token);
        if (activeJob is not null)
        {
            await RefreshActiveJob();
        }
    }

    private void OnFileSelected(InputFileChangeEventArgs args)
    {
        selectedFile = args.File;
        message = null;
    }

    private async Task ImportCsv()
    {
        if (selectedFile is null)
        {
            message = "اول فایل CSV را انتخاب کن.";
            return;
        }

        await Run(async () =>
        {
            message = await RunTrackedOperationAsync("import", async jobId =>
            {
                using var content = new MultipartFormDataContent();
                await using var stream = selectedFile.OpenReadStream(100_000_000, pageCancellation.Token);
                using var fileContent = new StreamContent(stream);
                fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("text/csv");
                content.Add(fileContent, "file", selectedFile.Name);
                var url = $"api/product-csv/import-all-product-with-process?tableName={Uri.EscapeDataString(tableName)}&truncate=false&jobId={jobId}";
                return await Api.PostAsync(url, content, pageCancellation.Token);
            });
            sourcePage = 1;
            await LoadSourceRows();
