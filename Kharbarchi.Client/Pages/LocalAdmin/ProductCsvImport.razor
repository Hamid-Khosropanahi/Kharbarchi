    private int WorkflowTotalPages => Math.Max(1, (int)Math.Ceiling(workflowTotalRows / (double)workflowPageSize));

    private string WorkflowTabTitle => activeWorkflowTab switch
    {
        "source" => "khb_source_product",
        "category" => "khb_category_map",
        "commodity" => "khb_commodity",
        "package" => "khb_package_type",
        "product" => "khb_product_final",
