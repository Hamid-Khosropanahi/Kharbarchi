@page "/local-admin/woocommerce-settings"
@attribute [Authorize]
@using System.Net.Http.Json
@using System.Text.Encodings.Web
@using System.Text.Json
@using System.Text.Json.Nodes
@using Microsoft.AspNetCore.Authorization
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<PageTitle>تنظیمات اتصال ووکامرس</PageTitle>

<section class="khb-page khb-page-premium khb-sand-filter">
    <div class="khb-page-hero khb-glass-card">
        <div>
            <span class="khb-eyebrow">WooCommerce Integration Lab</span>
            <h1>تنظیمات اتصال و تست API ووکامرس</h1>
            <p>این صفحه آزمایشگاه قدیمی API است. Secret و رمز WordPress در مرورگر ذخیره نمی‌شوند؛ برای اتصال پایدار از پروفایل‌های امن صفحه ورود CSV استفاده کنید.</p>
        </div>
        <div class="khb-hero-actions">
            <button class="khb-btn khb-btn-ghost" @onclick="LoadSettings">بارگذاری تنظیمات ذخیره‌شده</button>
            <button class="khb-btn khb-btn-primary" @onclick="SaveSettings">ذخیره موقت تنظیمات</button>
        </div>
    </div>

    <div class="khb-grid khb-grid-2">
        <div class="khb-glass-card khb-form-card">
            <h2>اطلاعات اتصال</h2>
            <label>آدرس اصلی سایت WooCommerce</label>
            <input class="khb-input" @bind="Model.BaseUrl" placeholder="https://localhost:4433/Kharbarchi" />

            <label>Consumer Key</label>
            <input class="khb-input ltr" @bind="Model.ConsumerKey" placeholder="ck_xxxxxxxxxxxxxxxxx" autocomplete="off" />

            <label>Consumer Secret</label>
            <input class="khb-input ltr" type="password" @bind="Model.ConsumerSecret" placeholder="cs_xxxxxxxxxxxxxxxxx" autocomplete="off" />

            <div class="khb-separator"></div>

            <h3>اطلاعات کاربر وردپرس</h3>
            <p class="khb-muted">برای بعضی endpointهای WordPress یا Application Password می‌توانی نام کاربری و پسورد وردپرس را هم وارد کنی. برای WooCommerce معمولاً همان Consumer Key/Secret کافی است.</p>

            <label>نام کاربری WordPress</label>
            <input class="khb-input ltr" @bind="Model.WordPressUsername" placeholder="admin / username" autocomplete="off" />

            <label>رمز یا Application Password وردپرس</label>
            <input class="khb-input ltr" type="password" @bind="Model.WordPressPassword" placeholder="xxxx xxxx xxxx xxxx" autocomplete="off" />

            <div class="khb-inline-fields">
                <div>
                    <label>Timeout ثانیه</label>
                    <input class="khb-input" type="number" min="5" max="300" @bind="Model.TimeoutSeconds" />
                </div>
                <div>
                    <label>Endpoint تست</label>
                    <input class="khb-input ltr" @bind="Model.EndpointPath" placeholder="wp-json/wc/v3/products?per_page=5" />
                </div>
            </div>

            <label class="khb-check-row">
                <input type="checkbox" @bind="Model.AllowInsecureLocalhostSsl" />
                <span>برای localhost گواهی SSL self-signed را قبول کن</span>
            </label>
        </div>

        <div class="khb-glass-card khb-status-card">
            <h2>تست اتصال</h2>
            <div class="khb-test-actions">
                <button class="khb-btn khb-btn-ghost" @onclick="TestServer" disabled="@Busy">تست سرور داخلی</button>
                <button class="khb-btn khb-btn-primary" @onclick="TestWoo" disabled="@Busy">تست ووکامرس</button>
                <button class="khb-btn khb-btn-soft" @onclick="TestProducts" disabled="@Busy">تست محصولات</button>
            </div>

            <div class="khb-state-pill @(LastOk ? "ok" : "warn")">
                @(Busy ? "در حال ارسال درخواست..." : LastMessage)
            </div>

            <label>Raw API Result</label>
            <textarea class="khb-result-box" readonly>@RawResult</textarea>
        </div>
    </div>
</section>

@code {
    private readonly WooLabRequest Model = new()
    {
        BaseUrl = "https://localhost:4433/Kharbarchi",
        EndpointPath = "wp-json/wc/v3/products?per_page=5",
        TimeoutSeconds = 600,
        AllowInsecureLocalhostSsl = true
    };

    private bool Busy;
    private bool LastOk;
    private string LastMessage = "هنوز تستی انجام نشده است.";
    private string RawResult = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadSettings();
            StateHasChanged();
        }
    }

    private HttpClient Api => HttpClientFactory.CreateClient("KharbarchiAPI");

    private async Task LoadSettings()
    {
        Model.BaseUrl = await GetLocal("khb.woo.baseUrl") ?? Model.BaseUrl;
        Model.ConsumerKey = await GetLocal("khb.woo.consumerKey") ?? Model.ConsumerKey;
        Model.WordPressUsername = await GetLocal("khb.woo.wpUsername") ?? Model.WordPressUsername;
        LastMessage = "تنظیمات ذخیره‌شده از مرورگر خوانده شد.";
        LastOk = true;
    }

    private async Task SaveSettings()
    {
        await SetLocal("khb.woo.baseUrl", Model.BaseUrl);
        await SetLocal("khb.woo.consumerKey", Model.ConsumerKey);
        await SetLocal("khb.woo.wpUsername", Model.WordPressUsername);
        LastMessage = "تنظیمات به‌صورت موقت در مرورگر ذخیره شد.";
        LastOk = true;
    }

    private async Task TestServer()
    {
        await Run(async () =>
        {
            var response = await Api.GetAsync("api/woo-lab/server-health");
            await ReadResponse(response);
        }, "ارتباط با سرور داخلی برقرار است.");
    }

    private async Task TestWoo()
    {
        await SaveSettings();
        await Run(async () =>
        {
            var response = await Api.PostAsJsonAsync("api/woo-lab/test-woocommerce", Model);
            await ReadResponse(response);
        }, "تست ووکامرس انجام شد.");
    }

    private async Task TestProducts()
    {
        Model.EndpointPath = "wp-json/wc/v3/products?per_page=5";
        await SaveSettings();
        await TestWoo();
    }

    private async Task Run(Func<Task> action, string okMessage)
    {
        Busy = true;
        LastOk = false;
        LastMessage = "در حال انجام درخواست...";
        try
        {
            await action();
            LastOk = true;
            LastMessage = okMessage;
        }
        catch (Exception ex)
        {
            LastOk = false;
            LastMessage = "خطا در اتصال یا پردازش API";
            RawResult = ToReadablePersian(ex.ToString());
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task ReadResponse(HttpResponseMessage response)
    {
        var text = await response.Content.ReadAsStringAsync();
        RawResult = ToReadablePersian(text);
        if (!response.IsSuccessStatusCode)
        {
            throw new InvalidOperationException($"HTTP {(int)response.StatusCode} {response.ReasonPhrase}\n{RawResult}");
        }
    }

    private static string ToReadablePersian(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        try
        {
            var node = JsonNode.Parse(text);
            return node?.ToJsonString(new JsonSerializerOptions
            {
                WriteIndented = true,
                Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping
            }) ?? text;
        }
        catch
        {
            return text;
        }
    }

    private async Task<string?> GetLocal(string key)
        => await JS.InvokeAsync<string?>("localStorage.getItem", key);

    private async Task SetLocal(string key, string? value)
        => await JS.InvokeVoidAsync("localStorage.setItem", key, value ?? string.Empty);

    private sealed class WooLabRequest
    {
        public string? BaseUrl { get; set; }
        public string? ConsumerKey { get; set; }
        public string? ConsumerSecret { get; set; }
        public string? WordPressUsername { get; set; }
        public string? WordPressPassword { get; set; }
        public string? EndpointPath { get; set; }
        public int TimeoutSeconds { get; set; } = 60;
        public bool AllowInsecureLocalhostSsl { get; set; } = true;
        public int PerPage { get; set; } = 100;
        public int MaxPages { get; set; } = 3;
    }
}
