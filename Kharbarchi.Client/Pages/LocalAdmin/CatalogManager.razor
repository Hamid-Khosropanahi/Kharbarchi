@page "/local-admin/catalog"
@attribute [Authorize]
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@inject IHttpClientFactory ClientFactory

<PageTitle>مرکز کنترل کاتالوگ خواربارچی</PageTitle>

<section class="khb-control-page" dir="rtl">
    <header class="khb-control-hero">
        <div>
            <span class="khb-eyebrow">Kharbarchi Control Center</span>
            <h1>کاتالوگ، قیمت، موجودی و ارسال امن به WooCommerce</h1>
            <p>هر محصول با اصل اتوماسیون، کنترل خطای انسانی و وضعیت سبز/زرد/قرمز مدیریت می‌شود. محصول قرمز برای انتشار متوقف می‌شود.</p>
        </div>
        <div class="khb-control-actions">
            <button class="khb-btn khb-btn-primary" @onclick="LoadAll" disabled="@Busy">به‌روزرسانی</button>
            <button class="khb-btn khb-btn-soft" @onclick="RunBatchSync" disabled="@Busy">ارسال مرحله‌ای Woo</button>
            <a class="khb-btn khb-btn-ghost" href="/local-admin">داشبورد</a>
        </div>
    </header>

    <section class="khb-control-stats">
        <article class="khb-stat green"><span>سبز</span><strong>@Summary.GreenProducts</strong><small>آماده انتشار</small></article>
        <article class="khb-stat yellow"><span>زرد</span><strong>@Summary.YellowProducts</strong><small>نیازمند بررسی</small></article>
        <article class="khb-stat red"><span>قرمز</span><strong>@Summary.RedProducts</strong><small>عدم انتشار</small></article>
        <article class="khb-stat"><span>صف Woo</span><strong>@Summary.PendingWooSync</strong><small>در انتظار ارسال</small></article>
        <article class="khb-stat"><span>موجودی کم</span><strong>@Summary.LowStockProducts</strong><small>ERP/Woo</small></article>
        <article class="khb-stat"><span>سفارش باز</span><strong>@Summary.OpenOrders</strong><small>نیازمند پیگیری</small></article>
    </section>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <section class="khb-control-message @MessageKind">@Message</section>
    }

    <nav class="khb-control-tabs">
        <button class="@(ActiveTab == "products" ? "active" : "")" @onclick='() => SetTab("products")'>محصولات</button>
        <button class="@(ActiveTab == "editor" ? "active" : "")" @onclick='() => SetTab("editor")'>ویرایش محصول</button>
        <button class="@(ActiveTab == "sync" ? "active" : "")" @onclick='() => SetTab("sync")'>ارسال WooCommerce</button>
        <button class="@(ActiveTab == "orders" ? "active" : "")" @onclick='() => SetTab("orders")'>سفارش‌ها و دریافت</button>
    </nav>

    @if (ActiveTab == "products")
    {
        <section class="khb-control-card">
            <div class="khb-control-toolbar">
                <div>
                    <h2>محصولات قابل فروش</h2>
                    <p>قیمت شرایطی قیمت رسمی است؛ قیمت نقدی تخفیف تسویه نقدی محسوب می‌شود.</p>
                </div>
                <div class="khb-control-filters">
                    <input placeholder="جستجو نام، SKU، دسته..." @bind="Search" @bind:event="oninput" />
                    <select @bind="StatusFilter">
                        <option value="all">همه وضعیت‌ها</option>
                        <option value="green">سبز</option>
                        <option value="yellow">زرد</option>
                        <option value="red">قرمز</option>
                    </select>
                    <button class="khb-btn" @onclick="LoadProducts" disabled="@Busy">جستجو</button>
                </div>
            </div>

            <div class="khb-control-table-wrap">
                <table class="khb-control-table">
                    <thead>
                        <tr>
                            <th>کنترل</th>
                            <th>محصول</th>
                            <th>قیمت فروش</th>
                            <th>تخفیف نقدی</th>
                            <th>قیمت کیلویی</th>
                            <th>واحد خرید</th>
                            <th>موجودی</th>
                            <th>Woo</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Products)
                        {
                            <tr class="status-@item.PriceCheckStatus">
                                <td><span class="khb-check-dot @item.PriceCheckStatus"></span><b>@StatusTitle(item.PriceCheckStatus)</b><small>@item.PriceCheckCode</small></td>
                                <td><strong>@item.Name</strong><small class="ltr">@item.Sku</small><small>@item.CategoryName / @item.BrandName</small></td>
                                <td>@Money(item.SaleCreditPrice)</td>
                                <td>@Money(item.CashDiscount)</td>
                                <td>@Money(item.SaleCreditPricePerKg)</td>
                                <td>@item.PackageTitle<br /><small>@WeightText(item)</small></td>
                                <td>@item.StockQuantity</td>
                                <td><span class="khb-badge">@item.WooSyncStatus</span><small>@item.WooCommerceProductId</small></td>
                                <td>
                                    <button class="khb-mini" @onclick="() => EditProduct(item.ProductId)">ویرایش</button>
                                    <button class="khb-mini primary" @onclick="() => SyncProduct(item.ProductId)" disabled="@(Busy || IsRed(item.PriceCheckStatus))">ارسال</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }

    @if (ActiveTab == "editor")
    {
        <section class="khb-control-card khb-editor-grid">
            @if (EditModel is null)
            {
                <div class="khb-empty-state">از تب محصولات، یک کالا را برای ویرایش انتخاب کن.</div>
            }
            else
            {
                <div class="khb-editor-main">
                    <div class="khb-editor-head">
                        <div>
                            <span class="khb-check-dot @EditModel.PriceCheckStatus"></span>
                            <h2>@EditModel.Name</h2>
                            <p>@EditModel.PriceCheckNote</p>
                        </div>
                        <div class="khb-editor-actions">
                            <button class="khb-btn khb-btn-primary" @onclick="SaveProduct" disabled="@Busy">ذخیره و کنترل</button>
                            <button class="khb-btn" @onclick="ValidateProduct" disabled="@Busy">فقط کنترل</button>
                            <button class="khb-btn khb-btn-soft" @onclick="SyncEditedProduct" disabled="@(Busy || IsRed(EditModel.PriceCheckStatus))">ارسال به Woo</button>
                        </div>
                    </div>

                    <div class="khb-form-grid">
                        <label>نام محصول<input @bind="EditModel.Name" /></label>
                        <label>Slug<input class="ltr" @bind="EditModel.Slug" /></label>
                        <label>SKU<input class="ltr" @bind="EditModel.Sku" /></label>
                        <label>Woo ID<input class="ltr" type="number" @bind="EditModel.WooCommerceProductId" /></label>
                        <label>
                            دسته‌بندی
                            <select @bind="EditModel.CategoryId">
                                @foreach (var l in Lookups.Categories)
                                {
                                    <option value="@l.Id">@l.Name</option>
                                }
                            </select>
                        </label>
                        <label>
                            برند
                            <select @bind="EditModel.BrandId">
                                <option value="">بدون برند</option>
                                @foreach (var l in Lookups.Brands)
                                {
                                    <option value="@l.Id">@l.Name</option>
                                }
                            </select>
                        </label>
                        <label>
                            کالای پایه
                            <select @bind="EditModel.CommodityId">
                                <option value="">بدون کالای پایه</option>
                                @foreach (var l in Lookups.Commodities)
                                {
                                    <option value="@l.Id">@l.Name</option>
                                }
                            </select>
                        </label>
                        <label>
                            وضعیت
                            <select @bind="EditModel.IsAvailable">
                                <option value="true">فعال</option>
                                <option value="false">غیرفعال</option>
                            </select>
                        </label>
                    </div>

                    <h3>قیمت و کنترل خودکار</h3>
                    <div class="khb-form-grid money">
                        <label>قیمت فروش کالا/شرایطی<input type="number" @bind="EditModel.SaleCreditPrice" /></label>
                        <label>قیمت نقدی<input type="number" @bind="EditModel.SaleCashPrice" /></label>
                        <label>خرید شرایطی<input type="number" @bind="EditModel.BuyCreditPrice" /></label>
                        <label>خرید نقد<input type="number" @bind="EditModel.BuyCashPrice" /></label>
                        <label>فروش کیلویی شرایطی<input type="number" @bind="EditModel.SaleCreditPricePerKg" /></label>
                        <label>فروش کیلویی نقد<input type="number" @bind="EditModel.SaleCashPricePerKg" /></label>
                        <label>خرید کیلویی شرایطی<input type="number" @bind="EditModel.BuyCreditPricePerKg" /></label>
                        <label>خرید کیلویی نقد<input type="number" @bind="EditModel.BuyCashPricePerKg" /></label>
                    </div>

                    <h3>بسته‌بندی، وزن و حداقل خرید</h3>
                    <div class="khb-form-grid">
                        <label>گروه بسته‌بندی<select @bind="EditModel.PackageGroup"><option value="retail">بسته‌بندی / کارتن</option><option value="bulk">فله / گونی</option><option value="none">بدون بسته‌بندی</option></select></label>
                        <label>کد بسته<input class="ltr" @bind="EditModel.PackageCode" /></label>
                        <label>عنوان بسته<input @bind="EditModel.PackageTitle" /></label>
                        <label>تگ تصویر<input @bind="EditModel.ImageTag" /></label>
                        <label>وزن هر بسته kg<input type="number" step="0.001" @bind="EditModel.UnitWeightKg" /></label>
                        <label>تعداد در کارتن<input type="number" @bind="EditModel.ProductCartonCount" /></label>
                        <label>وزن فله kg<input type="number" step="0.001" @bind="EditModel.BulkWeightKg" /></label>
                        <label>حداقل خرید kg<input type="number" step="0.001" @bind="EditModel.MinPurchaseKg" /></label>
                        <label>حداقل کارتن<input type="number" @bind="EditModel.MinCartons" /></label>
                        <label>گام خرید<input type="number" @bind="EditModel.CartonStep" /></label>
                        <label>واحد Woodmart<input @bind="EditModel.WoodmartPriceUnitOfMeasure" /></label>
                        <label>موجودی ERP/Woo<input type="number" @bind="EditModel.StockQuantity" /></label>
                    </div>

                    <label class="wide">توضیحات<textarea rows="4" @bind="EditModel.Description"></textarea></label>
                </div>

                <aside class="khb-control-side">
                    <h3>خروجی کنترل</h3>
                    <div class="khb-check-big @EditModel.PriceCheckStatus">@StatusTitle(EditModel.PriceCheckStatus)</div>
                    <dl>
                        <dt>کد</dt><dd>@EditModel.PriceCheckCode</dd>
                        <dt>اختلاف مبلغ</dt><dd>@Money(EditModel.PriceCheckAmount)</dd>
                        <dt>اختلاف درصد</dt><dd>@Percent(EditModel.PriceCheckPercent)</dd>
                        <dt>Expected فروش شرایطی</dt><dd>@Money(EditModel.ExpectedSaleCreditPrice)</dd>
                        <dt>Expected فروش نقد</dt><dd>@Money(EditModel.ExpectedSaleCashPrice)</dd>
                        <dt>Expected خرید شرایطی</dt><dd>@Money(EditModel.ExpectedBuyCreditPrice)</dd>
                        <dt>Expected خرید نقد</dt><dd>@Money(EditModel.ExpectedBuyCashPrice)</dd>
                    </dl>
                </aside>
            }
        </section>
    }

    @if (ActiveTab == "sync")
    {
        <section class="khb-control-card">
            <div class="khb-control-toolbar">
                <div><h2>ارسال مرحله‌ای به WooCommerce</h2><p>Batch کوچک باعث می‌شود خطاها قابل ردیابی باشند و UI قفل نشود.</p></div>
                <div class="khb-control-filters"><input type="number" min="1" max="50" @bind="BatchTake" /><button class="khb-btn khb-btn-primary" @onclick="RunBatchSync" disabled="@Busy">اجرای Batch</button></div>
            </div>
            <div class="khb-progress"><span style="width:@WooProgress.Percent%"></span></div>
            <p>@WooProgress.Synced از @WooProgress.Total ارسال شده، @WooProgress.Pending در انتظار، @WooProgress.Failed خطادار.</p>
            <div class="khb-control-table-wrap">
                <table class="khb-control-table"><thead><tr><th>محصول</th><th>SKU</th><th>Woo ID</th><th>وضعیت</th><th>پیام</th></tr></thead><tbody>@foreach(var r in SyncItems){<tr><td>@r.Name</td><td class="ltr">@r.Sku</td><td>@r.WooCommerceProductId</td><td>@r.Status</td><td>@r.Message</td></tr>}</tbody></table>
            </div>
        </section>
    }

    @if (ActiveTab == "orders")
    {
        <section class="khb-control-card">
            <div class="khb-control-toolbar"><div><h2>تأیید سفارش و ثبت دریافتی ERP</h2><p>دریافتی ERP به WooCommerce به‌صورت meta و وضعیت پرداخت منتقل می‌شود.</p></div><div class="khb-control-filters"><input placeholder="جستجوی سفارش" @bind="OrderSearch" @bind:event="oninput" /><button class="khb-btn" @onclick="LoadOrders" disabled="@Busy">جستجو</button></div></div>
            <div class="khb-control-table-wrap">
                <table class="khb-control-table">
                    <thead>
                        <tr>
                            <th>سفارش</th>
                            <th>مشتری</th>
                            <th>وضعیت</th>
                            <th>مبلغ</th>
                            <th>دریافتی فعلی</th>
                            <th>ثبت دریافتی ERP</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Orders)
                        {
                            <tr>
                                <td><b>@o.WooCommerceOrderNumber</b><small>@o.WooCommerceOrderId</small></td>
                                <td>@o.CustomerFullName<br /><small>@o.CustomerPhone</small></td>
                                <td>@o.InternalStatus<br /><small>@o.PaymentStatus</small></td>
                                <td>@Money(o.TotalAmount)</td>
                                <td>@Money(o.ReceivedAmount)</td>
                                <td>
                                    <div class="khb-inline-form">
                                        <input type="number" step="1" @bind="o.NewReceivedAmount" placeholder="مبلغ" />
                                        <select @bind="o.NewPaymentType">
                                            <option value="credit">شرایطی</option>
                                            <option value="cash">نقدی</option>
                                            <option value="bank_transfer">واریز بانکی</option>
                                            <option value="pos">کارتخوان</option>
                                        </select>
                                    </div>
                                </td>
                                <td>
                                    <button class="khb-mini" @onclick="() => ConfirmOrder(o.LocalOrderId)">تأیید</button>
                                    <button class="khb-mini primary" @onclick="() => MarkReceived(o)">ثبت دریافت</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</section>

@code {
    private HttpClient Api => ClientFactory.CreateClient("KharbarchiAPI");
    private bool Busy;
    private string ActiveTab = "products";
    private string Search = string.Empty;
    private string StatusFilter = "all";
    private string OrderSearch = string.Empty;
    private string? Message;
    private string MessageKind = "info";
    private int BatchTake = 5;
    private SummaryDto Summary = new();
    private LookupResponse Lookups = new();
    private ProgressDto WooProgress = new();
    private List<ProductItem> Products = new();
    private List<SyncItem> SyncItems = new();
    private List<OrderItem> Orders = new();
    private ProductEdit? EditModel;

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        Busy = true;
        try
        {
            Lookups = await Api.GetFromJsonAsync<LookupResponse>("api/admin/catalog/lookups") ?? new();
            Summary = await Api.GetFromJsonAsync<SummaryDto>("api/admin/kharbarchi-control/summary") ?? new();
            WooProgress = await Api.GetFromJsonAsync<ProgressDto>("api/admin/kharbarchi-control/woocommerce/progress") ?? new();
            await LoadProducts();
            await LoadOrders();
        }
        finally { Busy = false; }
    }

    private async Task LoadProducts()
    {
        Products = await Api.GetFromJsonAsync<List<ProductItem>>($"api/admin/kharbarchi-control/products?search={Uri.EscapeDataString(Search)}&status={StatusFilter}&pageSize=100") ?? new();
    }

    private async Task LoadOrders()
    {
        Orders = await Api.GetFromJsonAsync<List<OrderItem>>($"api/admin/kharbarchi-control/orders?search={Uri.EscapeDataString(OrderSearch)}&pageSize=50") ?? new();
    }

    private void SetTab(string tab) => ActiveTab = tab;

    private async Task EditProduct(int id)
    {
        ActiveTab = "editor";
        EditModel = await Api.GetFromJsonAsync<ProductEdit>($"api/admin/kharbarchi-control/products/{id}");
    }

    private async Task SaveProduct()
    {
        if (EditModel is null) return;
        Busy = true;
        try
        {
            var response = await Api.PutAsJsonAsync($"api/admin/kharbarchi-control/products/{EditModel.ProductId}", EditModel);
            if (!response.IsSuccessStatusCode) { await Fail(response); return; }
            EditModel = await response.Content.ReadFromJsonAsync<ProductEdit>();
            MessageKind = "success"; Message = "محصول ذخیره و کنترل شد.";
            await LoadProducts(); await LoadSummaryOnly();
        }
        finally { Busy = false; }
    }

    private async Task ValidateProduct()
    {
        if (EditModel is null) return;
        var response = await Api.PostAsJsonAsync($"api/admin/kharbarchi-control/products/{EditModel.ProductId}/validate", new { });
        if (!response.IsSuccessStatusCode) { await Fail(response); return; }
        EditModel = await response.Content.ReadFromJsonAsync<ProductEdit>();
    }

    private async Task SyncEditedProduct()
    {
        if (EditModel is null) return;
        await SyncProduct(EditModel.ProductId);
    }

    private async Task SyncProduct(int id)
    {
        Busy = true;
        try
        {
            var response = await Api.PostAsJsonAsync($"api/admin/kharbarchi-control/products/{id}/sync-woocommerce", new { });
            if (!response.IsSuccessStatusCode) { await Fail(response); return; }
            var item = await response.Content.ReadFromJsonAsync<SyncItem>();
            SyncItems.Insert(0, item ?? new());
            MessageKind = item?.Status == "synced" ? "success" : "warning";
            Message = item?.Message;
            await LoadProducts(); await LoadSummaryOnly();
        }
        finally { Busy = false; }
    }

    private async Task RunBatchSync()
    {
        Busy = true;
        try
        {
            var response = await Api.PostAsJsonAsync($"api/admin/kharbarchi-control/woocommerce/sync-batch?take={BatchTake}&pendingOnly=true", new { });
            if (!response.IsSuccessStatusCode) { await Fail(response); return; }
            var result = await response.Content.ReadFromJsonAsync<SyncResult>();
            SyncItems = result?.Items ?? new();
            WooProgress = await Api.GetFromJsonAsync<ProgressDto>("api/admin/kharbarchi-control/woocommerce/progress") ?? new();
            MessageKind = result?.Failed > 0 ? "warning" : "success";
            Message = $"Batch تمام شد: {result?.Synced ?? 0} ارسال، {result?.Failed ?? 0} خطا، {result?.Skipped ?? 0} رد شد.";
            await LoadProducts(); await LoadSummaryOnly();
        }
        finally { Busy = false; }
    }

    private async Task ConfirmOrder(long id)
    {
        var response = await Api.PostAsJsonAsync($"api/admin/kharbarchi-control/orders/{id}/confirm", new { internalStatus = "ReadyToShip", sendToWooCommerce = true, note = "تأیید سفارش در ERP" });
        if (!response.IsSuccessStatusCode) { await Fail(response); return; }
        MessageKind = "success"; Message = "سفارش تأیید شد."; await LoadOrders(); await LoadSummaryOnly();
    }

    private async Task MarkReceived(OrderItem order)
    {
        var amount = order.NewReceivedAmount > 0 ? order.NewReceivedAmount : order.TotalAmount;
        var response = await Api.PostAsJsonAsync($"api/admin/kharbarchi-control/orders/{order.LocalOrderId}/received-payment", new { receivedAmount = amount, paymentType = order.NewPaymentType, setPaidWhenFull = true, sendToWooCommerce = true, note = "ثبت دریافتی ERP" });
        if (!response.IsSuccessStatusCode) { await Fail(response); return; }
        MessageKind = "success"; Message = "دریافتی سفارش ثبت و به WooCommerce ارسال شد."; await LoadOrders(); await LoadSummaryOnly();
    }

    private async Task LoadSummaryOnly()
    {
        Summary = await Api.GetFromJsonAsync<SummaryDto>("api/admin/kharbarchi-control/summary") ?? new();
        WooProgress = await Api.GetFromJsonAsync<ProgressDto>("api/admin/kharbarchi-control/woocommerce/progress") ?? new();
    }

    private async Task Fail(HttpResponseMessage response)
    {
        MessageKind = "error";
        Message = await response.Content.ReadAsStringAsync();
    }

    private static string Money(decimal? value) => value.HasValue ? value.Value.ToString("N0") + " تومان" : "-";
    private static string Percent(decimal? value) => value.HasValue ? value.Value.ToString("0.####") + "%" : "-";
    private static string StatusTitle(string? status) => status switch { "green" => "سبز", "yellow" => "زرد", "red" => "قرمز", _ => status ?? "-" };
    private static string WeightText(ProductItem item) => item.TotalWeightKg.HasValue ? $"{item.TotalWeightKg:0.###} کیلو" : "وزن نامشخص";
    private static bool IsRed(string? status) => string.Equals(status, "red", StringComparison.OrdinalIgnoreCase);

    private sealed class SummaryDto { public int TotalProducts { get; set; } public int GreenProducts { get; set; } public int YellowProducts { get; set; } public int RedProducts { get; set; } public int PendingWooSync { get; set; } public int FailedWooSync { get; set; } public int SyncedWooProducts { get; set; } public int LowStockProducts { get; set; } public int OpenOrders { get; set; } public int PaymentPendingOrders { get; set; } }
    private sealed class LookupResponse { public List<Lookup> Categories { get; set; } = new(); public List<Lookup> Brands { get; set; } = new(); public List<Lookup> Commodities { get; set; } = new(); }
    private sealed class Lookup { public int Id { get; set; } public string Name { get; set; } = string.Empty; public string Slug { get; set; } = string.Empty; }
    private sealed class ProgressDto { public int Total { get; set; } public int Synced { get; set; } public int Failed { get; set; } public int Pending { get; set; } public int Percent { get; set; } }
    private sealed class ProductItem { public int ProductId { get; set; } public string Name { get; set; } = string.Empty; public string? Sku { get; set; } public string CategoryName { get; set; } = string.Empty; public string? BrandName { get; set; } public decimal SaleCreditPrice { get; set; } public decimal? CashDiscount { get; set; } public decimal? SaleCreditPricePerKg { get; set; } public decimal? TotalWeightKg { get; set; } public int StockQuantity { get; set; } public string PackageGroup { get; set; } = string.Empty; public string? PackageTitle { get; set; } public string PriceCheckStatus { get; set; } = string.Empty; public string PriceCheckCode { get; set; } = string.Empty; public string? PriceCheckNote { get; set; } public string WooSyncStatus { get; set; } = string.Empty; public long? WooCommerceProductId { get; set; } public bool IsAvailable { get; set; } }
