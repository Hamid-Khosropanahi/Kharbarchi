@page "/local-admin/users"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Kharbarchi.Client.Services
@using Kharbarchi.Shared.Contracts
@inject UserAdminService UserAdmin

<PageTitle>کاربران و نقش‌ها</PageTitle>

<section class="khb-page-head">
    <div><span class="khb-eyebrow">Identity Center</span><h1>کاربران و نقش‌ها</h1><p>ساخت حساب داخلی، تخصیص نقش، قفل/فعال‌سازی و ریست رمز از یک صفحه امن.</p></div>
    <button class="khb-btn khb-btn-secondary" @onclick="LoadAsync" disabled="@busy">بارگیری مجدد</button>
</section>

@if (!string.IsNullOrWhiteSpace(message)) { <div class="khb-alert @(isError ? "danger" : "success")">@message</div> }

<section class="khb-two-col khb-two-col-wide">
    <article class="khb-panel khb-panel-elevated">
        <div class="khb-panel-title"><span>01</span><div><h2>ساخت کاربر جدید</h2><p>نام کاربری انگلیسی و حداقل یک نقش الزامی است.</p></div></div>
        <EditForm Model="createModel" OnValidSubmit="CreateUserAsync" class="khb-form-grid">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <label class="khb-field">نام کاربری <InputText class="khb-input ltr" @bind-Value="createModel.UserName" /></label>
            <label class="khb-field">نام کامل <InputText class="khb-input" @bind-Value="createModel.FullName" /></label>
            <label class="khb-field">ایمیل <InputText class="khb-input ltr" @bind-Value="createModel.Email" /></label>
            <label class="khb-field">رمز عبور <InputText type="password" class="khb-input ltr" @bind-Value="createModel.Password" /></label>
            <label class="khb-field">تکرار رمز <InputText type="password" class="khb-input ltr" @bind-Value="createModel.ConfirmPassword" /></label>
            <div class="khb-role-grid khb-field-full">
                @foreach (var role in roles)
                {
                    <label class="khb-role-card"><input type="checkbox" checked="@createModel.SelectedRoles.Contains(role.Name)" @onchange="e => ToggleCreateRole(role.Name, e.Value)" /><span><b>@role.PersianName</b><small>@role.Description</small></span></label>
                }
            </div>
            <button class="khb-btn khb-btn-primary khb-field-full" type="submit" disabled="@busy">ساخت کاربر</button>
        </EditForm>
    </article>

</section>

<section class="khb-panel khb-panel-elevated">
    <div class="khb-panel-heading"><div><h2>کاربران سیستم</h2><p>حداکثر ۵۰۰ کاربر داخلی برای مدیریت نمایش داده می‌شود.</p></div></div>
    @if (loading) { <p class="khb-muted">در حال بارگیری...</p> }
    else
    {
        <div class="khb-user-grid">
            @foreach (var user in users)
            {
                <article class="khb-user-card">
                    <header><div><b>@user.UserName</b><small>@user.FullName</small><small>@user.Email</small></div><span class="khb-status-badge @(user.IsLockedOut ? "bad" : "ok")">@(user.IsLockedOut ? "قفل" : "فعال")</span></header>
                    <div class="khb-role-grid compact">
                        @foreach (var role in roles)
                        {
                            <label class="khb-role-card"><input type="checkbox" checked="@selectedRoles[user.Id].Contains(role.Name)" @onchange="e => ToggleUserRole(user.Id, role.Name, e.Value)" /><span><b>@role.PersianName</b></span></label>
                        }
                    </div>
                    <div class="khb-field">
                        <label>رمز عبور جدید</label>
                        <input type="password" class="khb-input ltr" autocomplete="new-password" @bind="resetPasswords[user.Id]" />
                    </div>
                    <footer><button class="khb-btn khb-btn-primary" @onclick="() => SaveRolesAsync(user.Id)" disabled="@busy">ذخیره نقش‌ها</button><button class="khb-btn khb-btn-secondary" @onclick="() => ResetPasswordAsync(user.Id)" disabled="@(busy || string.IsNullOrWhiteSpace(resetPasswords[user.Id]))">ریست رمز</button><button class="khb-btn khb-btn-danger" @onclick="() => ToggleLockAsync(user)" disabled="@busy">@(user.IsLockedOut ? "فعال‌سازی" : "قفل")</button></footer>
                </article>
            }
        </div>
    }
</section>

@code {
    private readonly CreateUserFormModel createModel = new();
    private readonly Dictionary<string, HashSet<string>> selectedRoles = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> resetPasswords = new(StringComparer.Ordinal);
    private IReadOnlyList<LocalRoleDto> roles = [];
    private IReadOnlyList<LocalUserDto> users = [];
    private bool loading = true;
    private bool busy;
    private bool isError;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        loading = true; message = null;
        try
        {
            roles = await UserAdmin.GetRolesAsync();
            users = await UserAdmin.GetUsersAsync();
            selectedRoles.Clear();
            resetPasswords.Clear();
            foreach (var user in users)
            {
                selectedRoles[user.Id] = new HashSet<string>(user.Roles, StringComparer.OrdinalIgnoreCase);
                resetPasswords[user.Id] = string.Empty;
            }
        }
        catch (Exception ex) { isError = true; message = "خطا در بارگیری کاربران: " + ex.Message; }
        finally { loading = false; }
    }

    private async Task CreateUserAsync()
    {
        busy = true; isError = false; message = null;
        try
        {
            var result = await UserAdmin.CreateUserAsync(new CreateLocalUserRequest { UserName = createModel.UserName, Email = createModel.Email, FullName = createModel.FullName, Password = createModel.Password, ConfirmPassword = createModel.ConfirmPassword, Roles = createModel.SelectedRoles.OrderBy(x => x).ToList() });
            isError = !result.IsSuccess; message = result.Message;
            if (result.IsSuccess) { createModel.Clear(); await LoadAsync(); }
        }
        finally { busy = false; }
    }

    private void ToggleCreateRole(string role, object? value) { if (value is bool b && b) createModel.SelectedRoles.Add(role); else createModel.SelectedRoles.Remove(role); }
    private void ToggleUserRole(string userId, string role, object? value) { if (!selectedRoles.TryGetValue(userId, out var set)) selectedRoles[userId] = set = new(StringComparer.OrdinalIgnoreCase); if (value is bool b && b) set.Add(role); else set.Remove(role); }
    private async Task SaveRolesAsync(string id) { busy = true; var r = await UserAdmin.UpdateRolesAsync(id, selectedRoles[id].OrderBy(x => x).ToList()); isError = !r.IsSuccess; message = r.Message; busy = false; }
    private async Task ResetPasswordAsync(string id)
    {
        if (!resetPasswords.TryGetValue(id, out var password) || password.Length < 10)
        {
            isError = true;
            message = "رمز عبور جدید باید حداقل ۱۰ نویسه باشد.";
            return;
        }

        busy = true;
        try
        {
            var result = await UserAdmin.ResetPasswordAsync(id, password);
            isError = !result.IsSuccess;
            message = result.Message;
            if (result.IsSuccess)
            {
                resetPasswords[id] = string.Empty;
            }
        }
        finally
        {
            busy = false;
        }
    }
    private async Task ToggleLockAsync(LocalUserDto user) { busy = true; var r = await UserAdmin.SetLockStateAsync(user.Id, !user.IsLockedOut); isError = !r.IsSuccess; message = r.Message; await LoadAsync(); busy = false; }

    private sealed class CreateUserFormModel
    {
        [Required] public string UserName { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string? FullName { get; set; }
        [Required, MinLength(10)] public string Password { get; set; } = string.Empty;
        [Compare(nameof(Password))] public string ConfirmPassword { get; set; } = string.Empty;
        public HashSet<string> SelectedRoles { get; } = new(StringComparer.OrdinalIgnoreCase);
        public void Clear() { UserName = Email = FullName = Password = ConfirmPassword = string.Empty; SelectedRoles.Clear(); }
    }
}
