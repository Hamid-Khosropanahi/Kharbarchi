@page "/local-admin/barook-payment"
@using Kharbarchi.Shared.Contracts
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin,ShippingOrderManager")]
@inject Kharbarchi.Client.Services.OrderWorkflowClient Workflow

<PageTitle>پرداخت باروک</PageTitle>

<section class="khb-shell" dir="rtl">
    <div class="khb-card">
        <h1>ارسال اقلام سفارش به باروک و ساخت لینک پرداخت</h1>
        <p>شماره سفارش لوکال یا WooCommerce را وارد کن. سیستم اقلام سفارش را از دیتابیس لوکال می‌خواند و به Barook CPG ارسال می‌کند.</p>

        <div class="khb-grid">
            <label>Order Id یا Woo Order Id<input type="number" @bind="orderId" /></label>
            <label>نام صاحب فاکتور<input @bind="ownerName" /></label>
            <label>موبایل<input @bind="ownerMobile" /></label>
            <label>کد ملی<input @bind="ownerNationalCode" /></label>
            <label>Redirect Url<input @bind="redirectUrl" /></label>
            <label>تعداد روز بازپرداخت<input type="number" @bind="paymentDayCount" /></label>
        </div>

        <button class="khb-primary" @onclick="StartAsync" disabled="@busy">ارسال اقلام به باروک و ساخت لینک</button>
    </div>

    @if (startResult is not null)
    {
        <div class="khb-card result">
            <h2>لینک پرداخت ساخته شد</h2>
            <p>ExternalCode: <strong>@startResult.ExternalCode</strong></p>
            <p>SessionId: <strong>@startResult.SessionId</strong></p>
            <input readonly value="@startResult.PaymentUrl" />
            <div class="khb-actions">
                <a class="khb-link" href="@startResult.PaymentUrl" target="_blank">باز کردن صفحه پرداخت</a>
                <button @onclick="MarkSentAsync">ثبت ارسال لینک</button>
            </div>

            <h3>استعلام پرداخت</h3>
            <label>Token برای استعلام، اگر خالی باشد از توکن ذخیره‌شده استفاده می‌شود<input @bind="verifyToken" /></label>
            <button class="khb-primary" @onclick="VerifyAsync" disabled="@busy">استعلام و تایید پرداخت</button>
        </div>
    }

    @if (verifyResult is not null)
    {
        <div class="khb-alert @(verifyResult.IsPaid ? "ok" : "warn")">
            وضعیت باروک: @verifyResult.BarookStatus - @verifyResult.Message - Transaction: @verifyResult.TransactionId
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="khb-alert warn">@message</div>
    }
</section>

<style>
.khb-shell{padding:24px;background:#f7f4ef;min-height:100vh}.khb-card{background:#fff;border-radius:24px;padding:22px;margin-bottom:18px;box-shadow:0 12px 30px #0001}.khb-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:14px}.khb-grid label,.khb-card label{display:flex;flex-direction:column;gap:8px;font-weight:700}.khb-card input{border:1px solid #ddd;border-radius:12px;padding:10px}.khb-primary,.khb-actions button{border:0;border-radius:14px;padding:12px 16px;background:#2d6a4f;color:white;font-weight:700;margin-top:16px}.khb-actions{display:flex;gap:10px;align-items:center}.khb-link{border-radius:14px;padding:12px 16px;background:#1d3557;color:#fff;text-decoration:none}.khb-alert{border-radius:16px;padding:14px;margin-top:12px}.khb-alert.ok{background:#e9f5ec;border:1px solid #b7dfc4}.khb-alert.warn{background:#fff3cd;border:1px solid #ffe69c}
</style>

@code {
    private bool busy;
    private long orderId;
    private string ownerName = string.Empty;
    private string? ownerMobile;
    private string ownerNationalCode = string.Empty;
    private string redirectUrl = "https://localhost:7029/local-admin/barook-payment";
    private int paymentDayCount = 14;
    private string? verifyToken;
    private string? message;
    private StartBarookPaymentResponse? startResult;
    private VerifyBarookPaymentResponse? verifyResult;

    private async Task StartAsync()
    {
        busy = true; message = null; verifyResult = null;
        try
        {
            startResult = await Workflow.StartBarookPaymentAsync(orderId, new StartBarookPaymentRequest
            {
                OwnerName = ownerName,
                OwnerMobile = ownerMobile,
                OwnerNationalCode = ownerNationalCode,
                RedirectUrl = redirectUrl,
                PaymentDayCount = paymentDayCount
            });
        }
        catch (Exception ex) { message = ex.Message; }
        finally { busy = false; }
    }

    private async Task MarkSentAsync()
    {
        if (startResult is null) return;
        await Workflow.MarkPaymentLinkSentAsync(startResult.SessionId, new MarkBarookPaymentLinkSentRequest { Note = "لینک پرداخت برای مشتری ارسال شد." });
        message = "ارسال لینک ثبت شد.";
    }

    private async Task VerifyAsync()
    {
        if (startResult is null) return;
        busy = true; message = null;
        try
        {
            verifyResult = await Workflow.VerifyBarookPaymentAsync(startResult.SessionId, new VerifyBarookPaymentRequest { Token = verifyToken, SendResultToWooCommerce = true });
        }
        catch (Exception ex) { message = ex.Message; }
        finally { busy = false; }
    }
}
