@page "/auth/logout"
@using Kharbarchi.Client.Services
@using Microsoft.AspNetCore.Components
@inject AuthService AuthService
@inject NavigationManager Nav
@layout EmptyLayout

<PageTitle>Logout</PageTitle>

<div class="logout-container">
    <div class="logout-card">
        <div class="icon-wrapper">
            <svg class="logout-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
        </div>

        <h1 class="logout-title">خروج از اکانت؟</h1>
        <p class="logout-message">آیا قصد خروچ از اکانت خود را دارید؟</p>

        <div class="button-group">
            <button type="button" class="btn btn-logout" @onclick="@LogoutAsync">
                <span>بله ، خارج شو !</span>
            </button>
            <button type="button" class="btn btn-cancel" @onclick="@(() => Nav.NavigateTo("/"))">
                <span>خیر</span>
            </button>
        </div>
    </div>
</div>


@code
{
    public async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
