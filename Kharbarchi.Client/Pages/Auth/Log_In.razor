@page "/login"
@page "/Log_In"
@page "/auth/login"
@using System.ComponentModel.DataAnnotations
@using Kharbarchi.Client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>ورود به پنل مدیریت خواربارچی</PageTitle>

<div class="khb-auth-page" dir="rtl">
    <section class="khb-auth-card">
        <div class="khb-auth-logo">خ</div>
        <span class="khb-eyebrow">ورود امن</span>
        <h1>ورود به پنل مدیریت</h1>
        <p>برای مدیریت کاتالوگ، قیمت، انبار، سفارش و پرداخت‌ها وارد حساب داخلی خود شوید.</p>

        <EditForm Model="model" OnValidSubmit="HandleLoginAsync" class="khb-form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <label>
                نام کاربری
                <InputText class="khb-input" @bind-Value="model.UserName" autocomplete="username" />
            </label>

            <label>
                رمز عبور
                <InputText class="khb-input" type="password" @bind-Value="model.Password" autocomplete="current-password" />
            </label>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="khb-alert @(isError ? "khb-alert-danger" : "khb-alert-success")">@message</div>
            }

            <button class="khb-primary-btn" type="submit" disabled="@isBusy">
                @(isBusy ? "در حال ورود..." : "ورود به سامانه")
            </button>
        </EditForm>

    </section>
</div>

@code {
    private readonly LoginFormModel model = new();
    private bool isBusy;
    private bool isError;
    private string? message;

    private async Task HandleLoginAsync()
    {
        isBusy = true;
        isError = false;
        message = null;

        try
        {
            var result = await AuthService.LoginAsync(model.UserName, model.Password);
            if (result.IsSuccess)
            {
                message = "ورود موفقیت‌آمیز بود.";
                Navigation.NavigateTo("/local-admin", forceLoad: false);
                return;
            }

            isError = true;
            message = string.IsNullOrWhiteSpace(result.Message) ? "نام کاربری یا رمز عبور اشتباه است." : result.Message;
        }
        catch (Exception ex)
        {
            isError = true;
            message = $"خطا در ورود: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private sealed class LoginFormModel
    {
        [Required(ErrorMessage = "نام کاربری الزامی است.")]
        public string UserName { get; set; } = string.Empty;

        [Required(ErrorMessage = "رمز عبور الزامی است.")]
        public string Password { get; set; } = string.Empty;
    }
}
