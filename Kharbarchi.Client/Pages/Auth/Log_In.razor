@page "/login"
@page "/Log_In"
@page "/auth/login"
@using System.ComponentModel.DataAnnotations
@using Kharbarchi.Client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>ورود به پنل مدیریت خواربارچی</PageTitle>

<div class="khb-auth-page" dir="rtl">
    <section class="khb-login-card">
        <div class="khb-auth-logo">خواربارچی</div>
        <span class="khb-login-badge">ورود امن</span>
        <h1>ورود به پنل مدیریت</h1>
        <p>برای مدیریت کاتالوگ، قیمت، انبار، سفارش و پرداخت‌ها وارد حساب داخلی خود شوید.</p>

        <EditForm Model="model" OnValidSubmit="HandleLoginAsync" class="khb-login-form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <label>
                نام کاربری
                <InputText class="khb-input khb-field" @bind-Value="model.UserName" autocomplete="username" />
            </label>

            <label>
                رمز عبور
                <InputText class="khb-input khb-field" type="password" @bind-Value="model.Password" autocomplete="current-password" />
            </label>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="khb-alert @(isError ? "khb-alert-danger" : "khb-alert-success")">@message</div>
            }

            <button class="khb-login-button" type="submit" disabled="@isBusy">
                @(isBusy ? "در حال ورود..." : "ورود به سامانه")
            </button>
        </EditForm>

    </section>
</div>
