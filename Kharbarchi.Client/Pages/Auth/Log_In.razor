@code {
    private readonly LoginFormModel model = new();
    private bool isBusy;
    private bool isError;
    private string? message;

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private async Task HandleLoginAsync()
    {
        isBusy = true;
        isError = false;
        message = null;

        try
        {
            var result = await AuthService.LoginAsync(model.UserName, model.Password);
            if (result.IsSuccess)
            {
                message = "ورود موفقیت‌آمیز بود.";
                Navigation.NavigateTo(GetSafeReturnUrl(), forceLoad: false);
                return;
            }

            isError = true;
            message = string.IsNullOrWhiteSpace(result.Message) ? "نام کاربری یا رمز عبور اشتباه است." : result.Message;
        }
        catch (Exception ex)
        {
            isError = true;
            message = $"خطا در ورود: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private sealed class LoginFormModel
    {
        [Required(ErrorMessage = "نام کاربری الزامی است.")]
        public string UserName { get; set; } = string.Empty;

        [Required(ErrorMessage = "رمز عبور الزامی است.")]
        public string Password { get; set; } = string.Empty;
    }

    private string GetSafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/local-admin";
        }

        var relative = ReturnUrl.Trim().TrimStart('/');
        return relative.Contains("://", StringComparison.Ordinal)
            ? "/local-admin"
            : "/" + relative;
    }
}
