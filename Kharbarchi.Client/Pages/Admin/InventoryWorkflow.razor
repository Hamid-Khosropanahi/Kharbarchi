@page "/local-admin/inventory"
@attribute [Authorize(Roles = "SuperAdmin,Admin,PricingManager,WarehouseEmployee")]
@using Kharbarchi.Client.Services
@using Kharbarchi.Shared.Contracts
@using Kharbarchi.Shared.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@inject CatalogAdminClient CatalogClient
@inject InventoryWorkflowClient InventoryClient

<PageTitle>گردش کار موجودی انبار</PageTitle>

<div class="khb-workflow" dir="rtl">
    <header class="khb-admin-header">
        <div>
            <span class="khb-eyebrow">انبار لوکال خواربارچی</span>
            <h1>پیشنهاد موجودی، کسری و اضافه انبار</h1>
            <p>کارمند انبار قیمت‌ها را نمی‌بیند. هر تغییر موجودی باید اول مدیر قیمت‌گذاری و بعد مدیر کل تایید کند تا وارد صف ارسال WooCommerce شود.</p>
        </div>
        <button class="khb-btn khb-btn-soft" @onclick="LoadAsync">بروزرسانی</button>
    </header>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="khb-alert">@message</div>
    }

    <section class="khb-card">
        <EditForm Model="form" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <div class="khb-form-grid">
                <div>
                    <label>محصول</label>
                    <InputSelect class="khb-input" @bind-Value="form.ProductId">
                        <option value="0">انتخاب محصول</option>
                        @foreach (var product in products)
                        {
                            <option value="@product.Id">@product.Name - موجودی @product.StockQuantity</option>
                        }
                    </InputSelect>
                </div>
                <div>
                    <label>نوع اصلاح موجودی</label>
                    <InputSelect class="khb-input" @bind-Value="form.AdjustmentKind">
                        <option value="@InventoryAdjustmentKind.SetAbsoluteStock">ثبت موجودی نهایی</option>
                        <option value="@InventoryAdjustmentKind.IncreaseStock">اضافه انبار</option>
                        <option value="@InventoryAdjustmentKind.DecreaseStock">کاهش انبار</option>
                        <option value="@InventoryAdjustmentKind.Shortage">کسری انبار</option>
                        <option value="@InventoryAdjustmentKind.Excess">مازاد انبار</option>
                    </InputSelect>
                </div>
                <div>
                    <label>تعداد</label>
                    <InputNumber class="khb-input" @bind-Value="form.ProposedQuantity" />
                </div>
                <div class="khb-col-span-2">
                    <label>دلیل/توضیح</label>
                    <InputText class="khb-input" @bind-Value="form.Reason" />
                </div>
            </div>
            <button class="khb-btn" type="submit">ثبت پیشنهاد موجودی</button>
        </EditForm>
    </section>

    <section class="khb-card khb-card-wide">
        <div class="khb-section-title"><h2>پیشنهادهای موجودی</h2></div>
        <div class="khb-table-wrap">
            <table class="khb-table">
                <thead>
                    <tr>
                        <th>محصول</th><th>موجودی فعلی</th><th>نوع</th><th>تعداد</th><th>موجودی نهایی</th><th>وضعیت</th><th>ثبت‌کننده</th><th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in proposals)
                    {
                        <tr>
                            <td>@row.ProductName<br /><small>@row.Sku</small></td>
                            <td>@row.CurrentStockQuantity</td>
                            <td>@row.AdjustmentKind</td>
                            <td>@row.ProposedQuantity</td>
                            <td>@row.FinalStockQuantity</td>
                            <td>@row.Status</td>
                            <td>@row.CreatedByUserName</td>
                            <td class="khb-row-actions">
                                <AuthorizeView Roles="SuperAdmin,Admin,PricingManager">
                                    <button class="khb-link" @onclick="() => ApproveManagerAsync(row.Id)">تایید مدیر قیمت‌گذاری</button>
                                    <button class="khb-link khb-danger" @onclick="() => RejectAsync(row.Id)">رد</button>
                                </AuthorizeView>
                                <AuthorizeView Roles="SuperAdmin,Admin">
                                    <button class="khb-link" @onclick="() => ApproveSuperAdminAsync(row.Id)">تایید مدیر کل و صف ارسال</button>
                                </AuthorizeView>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@code {
    private List<AdminProductListItemDto> products = [];
    private List<InventoryProposalDto> proposals = [];
    private InventoryForm form = new();
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        products = (await CatalogClient.GetProductsAsync(null)).ToList();
        proposals = (await InventoryClient.GetProposalsAsync()).ToList();
    }

    private async Task SubmitAsync()
    {
        var response = await InventoryClient.CreateProposalAsync(new InventoryProposalCreateRequest
        {
            ProductId = form.ProductId,
            AdjustmentKind = form.AdjustmentKind,
            ProposedQuantity = form.ProposedQuantity,
            Reason = form.Reason
        });
        await FinishAsync(response, "پیشنهاد موجودی ثبت شد.");
        form = new();
    }

    private async Task ApproveManagerAsync(long id) => await FinishAsync(await InventoryClient.ApproveManagerAsync(id, "تایید موجودی از فرم لوکال"), "تایید مدیر قیمت‌گذاری انجام شد.");
    private async Task ApproveSuperAdminAsync(long id) => await FinishAsync(await InventoryClient.ApproveSuperAdminAsync(id, "تایید نهایی موجودی و ورود به صف ارسال"), "موجودی در صف ارسال مرکزی قرار گرفت.");
    private async Task RejectAsync(long id) => await FinishAsync(await InventoryClient.RejectAsync(id, "رد از فرم لوکال"), "پیشنهاد رد شد.");

    private async Task FinishAsync(HttpResponseMessage response, string success)
    {
        if (response.IsSuccessStatusCode)
        {
            message = success;
            await LoadAsync();
        }
        else
        {
            message = await response.Content.ReadAsStringAsync();
        }
    }

    private sealed class InventoryForm
    {
        public int ProductId { get; set; }
        public InventoryAdjustmentKind AdjustmentKind { get; set; } = InventoryAdjustmentKind.SetAbsoluteStock;
        public int ProposedQuantity { get; set; }
        public string? Reason { get; set; }
    }
}

<style>
.khb-workflow{padding:24px;background:#f7f7f4;color:#1f2933;font-family:Tahoma,Arial,sans-serif}.khb-admin-header{display:flex;justify-content:space-between;gap:24px;align-items:center;margin-bottom:20px}.khb-card{background:#fff;border:1px solid #e6e2d8;border-radius:18px;padding:18px;box-shadow:0 10px 30px rgba(0,0,0,.04)}.khb-card-wide{margin-top:18px}.khb-eyebrow{font-size:13px;color:#687076}.khb-form-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px}.khb-col-span-2{grid-column:span 2}.khb-input{width:100%;border:1px solid #d6d3ca;border-radius:12px;padding:10px 12px;background:#fff;min-height:42px}.khb-btn{border:0;border-radius:12px;background:#31572c;color:#fff;padding:10px 16px;margin-top:12px;cursor:pointer}.khb-btn-soft{background:#edf3ea;color:#31572c;border:1px solid #c9d8c4}.khb-alert{background:#fff7e6;border:1px solid #ffd68a;border-radius:14px;padding:12px 14px;margin-bottom:16px}.khb-table-wrap{overflow:auto}.khb-table{width:100%;border-collapse:collapse;margin-top:12px}.khb-table th,.khb-table td{border-bottom:1px solid #eee7dc;text-align:right;padding:10px}.khb-link{border:0;background:transparent;color:#31572c;text-decoration:underline;cursor:pointer;margin-inline:4px}.khb-danger{color:#b42318}.khb-row-actions{white-space:nowrap}@media(max-width:900px){.khb-form-grid{grid-template-columns:1fr}.khb-col-span-2{grid-column:span 1}}
</style>
