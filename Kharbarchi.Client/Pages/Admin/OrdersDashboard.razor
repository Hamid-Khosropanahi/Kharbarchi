@page "/local-admin/orders"
@using Kharbarchi.Shared.Contracts
@using Kharbarchi.Shared.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin,PricingManager,SalesManager,ShippingOrderManager,Accountant")]
@inject Kharbarchi.Client.Services.OrderWorkflowClient Workflow

<PageTitle>سفارش‌های لوکال</PageTitle>

<section class="khb-shell" dir="rtl">
    <div class="khb-header">
        <div>
            <h1>سفارش‌ها و وضعیت پرداخت/ارسال</h1>
            <p>مدیر فروش، مدیر ارسال و حسابداری می‌توانند سفارش‌ها و اقلام را ببینند. تغییرات پرداخت فقط طبق نقش مجاز انجام می‌شود.</p>
        </div>
        <button class="khb-primary" @onclick="LoadAsync">بروزرسانی لیست</button>
    </div>

    <div class="khb-toolbar">
        <input @bind="search" placeholder="جستجو: شماره سفارش، نام، موبایل" />
        <select @bind="internalStatus">
            <option value="">همه وضعیت‌ها</option>
            <option value="@WooOrderInternalStatus.AwaitingPayment">در انتظار پرداخت</option>
            <option value="@WooOrderInternalStatus.ReadyToShip">آماده ارسال</option>
            <option value="@WooOrderInternalStatus.Completed">تکمیل‌شده</option>
            <option value="@WooOrderInternalStatus.Cancelled">لغو شده</option>
        </select>
        <button class="khb-primary" @onclick="LoadAsync">اعمال فیلتر</button>
    </div>

    <div class="khb-layout">
        <div class="khb-list">
            @foreach (var order in orders)
            {
                <button class="khb-row @(selected?.Id == order.Id ? "active" : string.Empty)" @onclick="() => SelectAsync(order.Id)">
                    <strong>#@order.WooCommerceOrderNumber</strong>
                    <span>@order.CustomerFullName - @order.CustomerPhone</span>
                    <span>@order.TotalAmount.ToString("N0") @order.Currency</span>
                    <em>@Translate(order.InternalStatus) / @TranslatePayment(order.PaymentStatus)</em>
                </button>
            }
        </div>

        <div class="khb-card">
            @if (selected is null)
            {
                <p>یک سفارش را انتخاب کن.</p>
            }
            else
            {
                <h2>سفارش #@selected.WooCommerceOrderNumber</h2>
                <div class="khb-info">
                    <span>مشتری: @selected.CustomerFullName</span>
                    <span>موبایل: @selected.CustomerPhone</span>
                    <span>کد ملی: @selected.CustomerNationalCode</span>
                    <span>مبلغ: @selected.TotalAmount.ToString("N0") @selected.Currency</span>
                    <span>وضعیت: @Translate(selected.InternalStatus)</span>
                </div>

                <h3>اقلام سفارش</h3>
                <table>
                    <thead><tr><th>کالا</th><th>SKU</th><th>تعداد</th><th>فی</th><th>جمع</th></tr></thead>
                    <tbody>
                        @foreach (var item in selected.Items)
                        {
                            <tr><td>@item.Name</td><td>@item.Sku</td><td>@item.Quantity</td><td>@item.UnitPrice.ToString("N0")</td><td>@item.LineTotal.ToString("N0")</td></tr>
                        }
                    </tbody>
                </table>

                <div class="khb-actions">
                    <button @onclick="SetAwaitingPaymentAsync">تغییر به در انتظار پرداخت</button>
                    <button @onclick="SetReadyToShipAsync">آماده ارسال</button>
                </div>

                <h3>پرداخت‌های باروک</h3>
                @foreach (var p in selected.BarookPayments)
                {
                    <div class="khb-mini">
                        <strong>@p.ExternalCode</strong>
                        <span>@p.BarookStatus - @p.Amount.ToString("N0")</span>
                        <a href="@p.PaymentUrl" target="_blank">لینک پرداخت</a>
                    </div>
                }

                <h3>رسیدهای دستی حسابداری</h3>
                @foreach (var r in selected.ManualReceipts)
                {
                    <div class="khb-mini"><strong>@r.ReceiptNumber</strong><span>@r.Amount.ToString("N0") @r.Currency - @r.PaymentSource</span></div>
                }
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="khb-alert">@message</div>
    }
</section>

<style>
.khb-shell{padding:24px;background:#f7f4ef;min-height:100vh}.khb-header,.khb-toolbar,.khb-card{background:#fff;border-radius:24px;padding:20px;box-shadow:0 12px 30px #0001}.khb-header{display:flex;justify-content:space-between;gap:16px;align-items:center;margin-bottom:18px}.khb-toolbar{display:flex;gap:12px;margin-bottom:18px}.khb-toolbar input,.khb-toolbar select{border:1px solid #ddd;border-radius:12px;padding:10px}.khb-layout{display:grid;grid-template-columns:360px 1fr;gap:18px}.khb-list{display:flex;flex-direction:column;gap:10px}.khb-row{background:#fff;border:1px solid #eee;border-radius:18px;padding:14px;text-align:right;display:flex;flex-direction:column;gap:6px;cursor:pointer}.khb-row.active{outline:3px solid #95d5b2}.khb-info{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:8px;background:#fafafa;border-radius:16px;padding:12px}table{width:100%;border-collapse:collapse;margin-top:10px}th,td{border-bottom:1px solid #eee;padding:10px;text-align:right}.khb-actions{display:flex;gap:10px;margin:16px 0}.khb-actions button,.khb-primary{border:0;border-radius:14px;padding:11px 15px;background:#2d6a4f;color:#fff;font-weight:700}.khb-mini{display:flex;gap:12px;justify-content:space-between;background:#fafafa;border-radius:14px;padding:12px;margin:8px 0}.khb-alert{margin-top:18px;background:#e9f5ec;border:1px solid #b7dfc4;border-radius:16px;padding:14px}@media(max-width:900px){.khb-layout{grid-template-columns:1fr}.khb-header,.khb-toolbar{flex-direction:column;align-items:stretch}}
</style>

@code {
    private List<LocalWooOrderListItemDto> orders = [];
    private LocalWooOrderDetailsDto? selected;
    private string? search;
    private string? internalStatus;
    private string? message;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        message = null;
        orders = (await Workflow.GetOrdersAsync(internalStatus, null, search))?.ToList() ?? [];
    }

    private async Task SelectAsync(long id)
    {
        selected = await Workflow.GetOrderAsync(id);
    }

    private async Task SetAwaitingPaymentAsync()
    {
        if (selected is null) return;
        await Workflow.ChangeStatusAsync(selected.Id, new ChangeInternalOrderStatusRequest { InternalStatus = WooOrderInternalStatus.AwaitingPayment, Note = "توسط کاربر به در انتظار پرداخت تغییر کرد." });
        await SelectAsync(selected.Id); await LoadAsync();
    }

    private async Task SetReadyToShipAsync()
    {
        if (selected is null) return;
        await Workflow.ChangeStatusAsync(selected.Id, new ChangeInternalOrderStatusRequest { InternalStatus = WooOrderInternalStatus.ReadyToShip, Note = "توسط کاربر آماده ارسال شد." });
        await SelectAsync(selected.Id); await LoadAsync();
    }

    private static string Translate(string value) => value switch
    {
        WooOrderInternalStatus.AwaitingPayment => "در انتظار پرداخت",
        WooOrderInternalStatus.PaymentConfirmed => "پرداخت تایید شده",
        WooOrderInternalStatus.ReadyToShip => "آماده ارسال",
        WooOrderInternalStatus.Shipped => "ارسال شده",
        WooOrderInternalStatus.Completed => "تکمیل شده",
        WooOrderInternalStatus.Cancelled => "لغو شده",
        WooOrderInternalStatus.PaymentFailed => "پرداخت ناموفق",
        _ => value
    };

    private static string TranslatePayment(string value) => value switch
    {
        PaymentStatusNames.AwaitingPayment => "در انتظار پرداخت",
        PaymentStatusNames.Paid => "پرداخت شده",
        PaymentStatusNames.BarookPaid => "پرداخت باروک",
        PaymentStatusNames.ManualPaid => "دریافت دستی",
        PaymentStatusNames.Failed => "ناموفق",
        _ => value
    };
}
