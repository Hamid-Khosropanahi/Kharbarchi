@inject NavigationManager Navigation

@code
{
    protected override void OnInitialized()
    {
        // 1. Get the current URL the user is trying to visit
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);

        // 2. Redirect to login, attaching the current URL as a parameter
        // Use Uri.EscapeDataString to handle special characters like '/' or '?'
        Navigation.NavigateTo($"/auth/login?returnUrl={Uri.EscapeDataString(returnUrl)}");
    }
}
