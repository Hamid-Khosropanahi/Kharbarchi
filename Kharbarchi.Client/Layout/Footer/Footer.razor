                                      keyTimes="0; .6; 1"
                                      keySplines="0.42, 0, 0.58, 1.0;0.42, 0, 0.58, 1.0"
                                      repeatCount="indefinite" />
                </use>
                <use xlink:href="#wave" opacity=".9">
                    <animateTransform attributeName="transform"
                                      attributeType="XML"
                                      type="translate"
                                      dur="4s"
                                      calcMode="spline"
                                      values="0 230;-140 200;0 230"
                                      keyTimes="0; .4; 1"
                                      keySplines="0.42, 0, 0.58, 1.0;0.42, 0, 0.58, 1.0"
                                      repeatCount="indefinite" />
                </use>
            </g>
        </svg>
