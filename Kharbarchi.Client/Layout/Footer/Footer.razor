        <svg class="wave-svg"
             version="1.1"
             xmlns="http://www.w3.org/2000/svg"
             xmlns:xlink="http://www.w3.org/1999/xlink"
             viewBox="0 600 1600 300"
             preserveAspectRatio="none">
            <defs>
                <path id="wave"
                      fill="rgba(47, 172, 102, 0.6)"
                      d="M-363.852,502.589c0,0,236.988-41.997,505.475,0
