@inherits LayoutComponentBase
@using Kharbarchi.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IConfiguration Configuration
@inject ILogger<MainLayout> Logger

<div class="khb-shell">
    <div class="khb-admin-frame">
        <aside class="khb-sidebar" aria-label="منوی مدیریت خواربارچی">
            <div class="khb-brand">
                <Logo LogoUrl="Logo/LOGO.svg"
                      AltText="خواربارچی"
                      HomeUrl="/local-admin"
                      MaxWidth="74px"
                      CssClass="khb-admin-logo" />
                <div>
                    <strong>خواربارچی</strong>
                    <small>پنل مدیریت داخلی</small>
                </div>
            </div>

            <nav class="khb-nav" aria-label="منوی مدیریت">
    <div class="khb-nav-section">جنرال</div>
    <NavLink class="khb-nav-item" href="/local-admin" Match="NavLinkMatch.All"><span><i class="bi bi-grid-1x2-fill"></i></span><b>داشبورد</b></NavLink>
    <NavLink class="khb-nav-item" href="/account"><span><i class="bi bi-person-circle"></i></span><b>حساب کاربری</b></NavLink>
    <NavLink class="khb-nav-item" href="/local-admin/users"><span><i class="bi bi-people-fill"></i></span><b>کاربران و نقش‌ها</b></NavLink>
    <NavLink class="khb-nav-item" href="/local-admin/settings"><span><i class="bi bi-gear-fill"></i></span><b>تنظیمات سامانه</b></NavLink>

    <div class="khb-nav-section">فروش</div>
    <NavLink class="khb-nav-item" href="/local-admin/sales-order"><span><i class="bi bi-cart-plus-fill"></i></span><b>کاتالوگ و ثبت سفارش</b></NavLink>
    <NavLink class="khb-nav-item" href="/local-admin/customers"><span><i class="bi bi-person-vcard-fill"></i></span><b>مشتریان و اعتبار</b></NavLink>
    <NavLink class="khb-nav-item" href="/local-admin/orders"><span><i class="bi bi-receipt-cutoff"></i></span><b>سفارش‌ها</b></NavLink>

    <div class="khb-nav-section">انبار</div>
    <NavLink class="khb-nav-item" href="/local-admin/inventory"><span><i class="bi bi-box-seam-fill"></i></span><b>بسته‌بندی و موجودی</b></NavLink>

    <div class="khb-nav-section">کالا</div>
    <NavLink class="khb-nav-item" href="/local-admin/products"><span><i class="bi bi-boxes"></i></span><b>محصولات و ورود CSV</b></NavLink>
    <NavLink class="khb-nav-item" href="/local-admin/catalog"><span><i class="bi bi-tags-fill"></i></span><b>برند، دسته و مشخصات</b></NavLink>
    <NavLink class="khb-nav-item" href="/local-admin/pricing"><span><i class="bi bi-cash-coin"></i></span><b>قیمت‌گذاری</b></NavLink>

    <div class="khb-nav-section">مالی</div>
    <NavLink class="khb-nav-item" href="/local-admin/barook-payment"><span><i class="bi bi-credit-card-fill"></i></span><b>پرداخت باروک</b></NavLink>
    <NavLink class="khb-nav-item" href="/local-admin/accounting"><span><i class="bi bi-calculator-fill"></i></span><b>حسابداری</b></NavLink>

    <div class="khb-nav-section">سایت</div>
    <NavLink class="khb-nav-item" href="/local-admin/woocommerce-settings"><span><i class="bi bi-shop"></i></span><b>تنظیمات ووکامرس</b></NavLink>
    <NavLink class="khb-nav-item" href="/local-admin/woocommerce-import"><span><i class="bi bi-cloud-arrow-down-fill"></i></span><b>دریافت از ووکامرس</b></NavLink>
    <NavLink class="khb-nav-item" href="/local-admin/sync-outbox"><span><i class="bi bi-arrow-repeat"></i></span><b>صف ارسال تغییرات</b></NavLink>
</nav>


            <div class="khb-sidebar-footer">
                <a class="khb-store-button" href="@ShopUrl" target="_blank" rel="noopener">مشاهده فروشگاه قدیمی</a>
                <button class="khb-pill khb-theme-toggle" type="button" data-khb-theme-toggle>تغییر تم روشن/تاریک</button>
            </div>
        </aside>

        <main class="khb-main">
            <header class="khb-topbar">
                <button class="khb-pill khb-mobile-menu" type="button" data-khb-sidebar-toggle>☰ منو</button>
                <div class="khb-breadcrumb">
                    <strong>@PageTitle</strong>
                    <span>مدیریت امن، سریع و نقش‌محور خواربارچی</span>
                </div>
                <div class="khb-top-actions">
                    <a class="khb-pill" href="@ShopUrl" target="_blank" rel="noopener">فروشگاه قدیمی</a>
                    <a class="khb-pill" href="local-admin/woocommerce-settings">API ووکامرس</a>
                    <AuthorizeView>
                        <Authorized Context="auth">
                            <a class="khb-pill khb-account-pill" href="/account">@GetUserName(auth.User.Identity?.Name)</a>
                            <button class="khb-pill khb-logout-pill" type="button" @onclick="LogoutAsync">خروج</button>
                        </Authorized>
                        <NotAuthorized>
                            <a class="khb-pill" href="login">ورود</a>
                        </NotAuthorized>
                    </AuthorizeView>
                    <button class="khb-pill khb-theme-toggle" type="button" data-khb-theme-toggle>☾</button>
                </div>
            </header>

            <section class="khb-content">
                @Body
            </section>
        </main>
    </div>
</div>

@code {
    private string ShopUrl => Configuration["Site:ShopUrl"]
        ?? throw new InvalidOperationException("Site:ShopUrl is not configured.");

    private string PageTitle
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/').ToLowerInvariant();
            return path switch
            {
                "" => "خانه مدیریت",
                "account" => "حساب کاربری",
                "profile" => "حساب کاربری",
                "local-admin" => "داشبورد مدیریت",
                "local-admin/users" => "کاربران و نقش‌ها",
                "local-admin/settings" => "تنظیمات سامانه",
                "local-admin/woocommerce-settings" => "آزمایشگاه اتصال ووکامرس",
                "local-admin/woocommerce-import" => "ورود اطلاعات ووکامرس",
                "local-admin/catalog" => "کاتالوگ کالا",
                "local-admin/pricing" => "فرآیند قیمت‌گذاری",
                "local-admin/inventory" => "فرآیند انبار",
                "local-admin/orders" => "سفارش‌ها",
                "local-admin/sales-order" => "کاتالوگ و ثبت سفارش فروش",
                "local-admin/customers" => "مشتریان و اعتبار باروک",
                "local-admin/barook-payment" => "پرداخت باروک",
                "local-admin/accounting" => "حسابداری",
                "local-admin/sync-outbox" => "صف همگام‌سازی",
                _ => "پنل مدیریت خواربارچی"
            };
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("kharbarchiLux.init");
            }
            catch (JSException)
            {
                Logger.LogWarning("Optional ERP UX initialization was skipped because its JavaScript module was unavailable.");
            }
        }
    }

    private static string GetUserName(string? name)
        => string.IsNullOrWhiteSpace(name) ? "کاربر سامانه" : name;

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: false);
    }
}


