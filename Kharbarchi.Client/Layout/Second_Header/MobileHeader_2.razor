@inject HeaderState State

<div class="mobile-header">

    <button class="menu-btn" @onclick="State.ToggleMobileMenu">
        ☰
    </button>

    <a href="/" class="logo">
        <img src="css/For_Header/TypoGraphy@184.png" alt="Kharbarchi" />
    </a>

    <O_ShoppingCart />

</div>

@if (State.IsMobileMenuOpen)
{
    <div class="overlay" @onclick="State.CloseMobileMenu"></div>

    <nav class="mobile-menu open">
        <button class="close" @onclick="State.CloseMobileMenu">✕</button>

        <a href="/" @onclick="State.CloseMobileMenu">خانه</a>
        <a href="/shop" @onclick="State.CloseMobileMenu">فروشگاه</a>
        <a href="/mag" @onclick="State.CloseMobileMenu">مجله</a>
        <a href="/cart" @onclick="State.CloseMobileMenu">سبد خرید</a>
    </nav>
}