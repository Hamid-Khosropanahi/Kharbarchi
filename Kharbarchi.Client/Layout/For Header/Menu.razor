@using Kharbarchi.Shared.Security
@using Microsoft.AspNetCore.Components.Authorization

<nav class="@ResolveClass()" aria-label="@ResolveAriaLabel()" id="@ResolveId()" dir="rtl" @attributes="AdditionalAttributes">
    <ul class="@ResolveMenuClass()">
        <AuthorizeView Context="authContext">
            <Authorized>
                <li><NavLink href="/local-admin" Match="NavLinkMatch.All">داشبورد</NavLink></li>

                <AuthorizeView Roles="@KharbarchiRoles.SuperAdmins" Context="superAdminContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/users">کاربران</NavLink></li>
                        <li><NavLink href="/local-admin/sync-outbox">همگام‌سازی</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.CatalogWriters" Context="catalogContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/catalog">کالا</NavLink></li>
                        <li><NavLink href="/local-admin/woocommerce-import">ووکامرس</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.PriceProposers" Context="priceContext"><Authorized><li><NavLink href="/local-admin/pricing">قیمت</NavLink></li></Authorized></AuthorizeView>
                <AuthorizeView Roles="@KharbarchiRoles.InventoryProposers" Context="inventoryContext"><Authorized><li><NavLink href="/local-admin/inventory">انبار</NavLink></li></Authorized></AuthorizeView>
                <AuthorizeView Roles="@KharbarchiRoles.OrderViewersCsv" Context="orderContext"><Authorized><li><NavLink href="/local-admin/orders">سفارش‌ها</NavLink></li></Authorized></AuthorizeView>
                <AuthorizeView Roles="@KharbarchiRoles.BarookPaymentOperatorsCsv" Context="barookContext"><Authorized><li><NavLink href="/local-admin/barook-payment">باروک</NavLink></li></Authorized></AuthorizeView>
                <AuthorizeView Roles="@KharbarchiRoles.PaymentOperatorsCsv" Context="accountingContext"><Authorized><li><NavLink href="/local-admin/accounting">حسابداری</NavLink></li></Authorized></AuthorizeView>
            </Authorized>
            <NotAuthorized>
                <li><NavLink href="/login">ورود</NavLink></li>
            </NotAuthorized>
        </AuthorizeView>
    </ul>
</nav>

@code {
    [Parameter] public string? NavClass { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? MenuId { get; set; }
    [Parameter] public string? MenuClass { get; set; }
    [Parameter] public IEnumerable<object>? MenuItems { get; set; }

    [Parameter] public string? Base_Classes { get; set; }
    [Parameter] public string? Aria_Label { get; set; }
    [Parameter] public string? Menu_ID { get; set; }
    [Parameter] public string? Menu_Class { get; set; }
    [Parameter] public string? Ul_Class { get; set; }
    [Parameter] public IEnumerable<object>? Menu_Items { get; set; }
    [Parameter] public IEnumerable<object>? User_Menu { get; set; }

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolveClass() => FirstNotEmpty(NavClass, Base_Classes, "khb-shell-nav");
    private string ResolveAriaLabel() => FirstNotEmpty(AriaLabel, Aria_Label, "منوی اصلی مدیریت");
    private string ResolveId() => FirstNotEmpty(MenuId, Menu_ID, "khb-main-menu");
    private string ResolveMenuClass() => FirstNotEmpty(MenuClass, Menu_Class, Ul_Class, "khb-menu-list");

    private static string FirstNotEmpty(params string?[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return string.Empty;
    }
}
