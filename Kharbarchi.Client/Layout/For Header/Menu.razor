@using Kharbarchi.Shared.Security
@using Microsoft.AspNetCore.Components.Authorization

<nav class="@Safe(NavClass, "khb-main-nav")" aria-label="@Safe(AriaLabel, "منوی اصلی مدیریت")" id="@Safe(MenuId, "khb-main-menu")" dir="rtl">
    <ul class="@Safe(MenuClass, "khb-main-menu")">
        <AuthorizeView Context="authContext">
            <Authorized>
                <li><NavLink href="/local-admin" Match="NavLinkMatch.All">داشبورد</NavLink></li>

                <AuthorizeView Roles="@KharbarchiRoles.SuperAdmins" Context="superAdminContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/users">کاربران و نقش‌ها</NavLink></li>
                        <li><NavLink href="/local-admin/sync-outbox">صف همگام‌سازی</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.CatalogWriters" Context="catalogContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/catalog">کاتالوگ</NavLink></li>
                        <li><NavLink href="/local-admin/woocommerce-import">ورود از ووکامرس</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.PriceProposers" Context="priceContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/pricing">قیمت‌گذاری</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.InventoryProposers" Context="inventoryContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/inventory">انبار</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.OrderViewersCsv" Context="orderContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/orders">سفارش‌ها</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.BarookPaymentOperatorsCsv" Context="barookContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/barook-payment">پرداخت باروک</NavLink></li>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="@KharbarchiRoles.PaymentOperatorsCsv" Context="accountingContext">
                    <Authorized>
                        <li><NavLink href="/local-admin/accounting">حسابداری</NavLink></li>
                    </Authorized>
                </AuthorizeView>
            </Authorized>
            <NotAuthorized>
                <li><NavLink href="/login">ورود</NavLink></li>
            </NotAuthorized>
        </AuthorizeView>
    </ul>
</nav>

@code {
    [Parameter] public string? NavClass { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? MenuId { get; set; }
    [Parameter] public string? MenuClass { get; set; }

    // Kept only for compatibility with the old header. The old shop menu values are intentionally ignored.
    [Parameter] public object? MenuItems { get; set; }

    private static string Safe(string? value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }
}
