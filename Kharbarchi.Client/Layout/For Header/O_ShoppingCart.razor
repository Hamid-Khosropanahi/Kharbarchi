@using Kharbarchi.Client.Model.Header
@* O_ShoppingCart.razor *@
<div class="wd-header-cart wd-tools-element wd-design-2 cart-widget-opener whb-909xiifk7ve155p9rk10">
    <a href="./cart/" title="سبد خرید">
        <span class="bi bi-cart fs-4">
            <span class="top-0 start-100 translate-middle badge rounded-pill text-bg-success" style="font-size : 10px">
                @CartData.ItemCount <span></span>
            </span>
        </span>
        <span class="wd-tools-text">
            <span class="wd-cart-subtotal">
                <span class="Hd-Price-amount amount">
                    <bdi>@CartData.Total.ToString("N0")&nbsp;<span class="Hd-Price-currencySymbol">@CartData.Currency</span></bdi>
                </span>
            </span>
        </span>
    </a>
</div>

@code {

    [Parameter]
    public CartInfo CartData { get; set; } = new CartInfo() { 
   ItemCount=2,
   Currency="تومان",
   Total=3000
        
    
    };

    [Parameter]
    public string CartUrl { get; set; } = "./cart/";

    [Parameter]
    public string DesignClass { get; set; } = string.Empty;

    [Parameter]
    public string CssClass { get; set; } = string.Empty;
}