@using Kharbarchi.Client.Services
@using Kharbarchi.Shared.Security
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthService AuthService
@inject NavigationManager Navigation

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="khb-user-dropdown" dir="rtl">
            <button class="khb-user-trigger" type="button">
                <span class="khb-user-avatar">@GetAvatar(authContext.User)</span>
                <span>
                    <b>سلام، @GetDisplayName(authContext.User)</b>
                    <small>@GetPrimaryRole(authContext.User)</small>
                </span>
            </button>
            <div class="khb-user-menu">
                <a href="/local-admin">داشبورد مدیریت</a>
                <AuthorizeView Roles="@KharbarchiRoles.SuperAdmins" Context="adminContext">
                    <Authorized>
                        <a href="/local-admin/users">کاربران و نقش‌ها</a>
                    </Authorized>
                </AuthorizeView>
                <button type="button" @onclick="LogoutAsync">خروج</button>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <a class="khb-login-link" href="/login" dir="rtl">ورود به مدیریت</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    private static string GetDisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.FindFirst("full_name")?.Value
            ?? user.Identity?.Name
            ?? "کاربر";
    }

    private static string GetAvatar(System.Security.Claims.ClaimsPrincipal user)
    {
        var displayName = GetDisplayName(user).Trim();
        return string.IsNullOrEmpty(displayName) ? "خ" : displayName[..1];
    }

    private static string GetPrimaryRole(System.Security.Claims.ClaimsPrincipal user)
    {
        var role = user.Claims
            .Where(x => x.Type == System.Security.Claims.ClaimTypes.Role || x.Type.EndsWith("/role", StringComparison.OrdinalIgnoreCase))
            .Select(x => x.Value)
            .FirstOrDefault();

        return string.IsNullOrWhiteSpace(role) ? "بدون نقش" : KharbarchiRoles.GetDisplayName(role);
    }
}
