@namespace Kharbarchi.Client.Components.Header
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<div class="site-logo @CssClass @(HasStickyLogo ? "wd-switch-logo" : "")">

    <!-- MAIN LOGO (3D Container) -->
    <a href="@HomeUrl" class="wd-logo wd-main-logo" rel="home" aria-label="@AltText" style="max-width: @MaxWidth;">
        @if (Use3DLogo)
        {
            <div class="canvas-container" data-khb-logo-root data-logo-url="@ResolvedLogoUrl" @ref="logoRoot">
                <svg class="canvas" viewBox="-250 -250 500 500" role="img" aria-label="@AltText">
                    <g class="spinning-group">
                        <!-- Javascript will inject layers here -->
                    </g>
                </svg>
            </div>
        }
        else
        {
            <img src="@ResolvedLogoUrl"
                 alt="@AltText"
                 style="max-width: @MaxWidth;"
                 loading="lazy"
                 @attributes="AdditionalAttributes">
        }
    </a>

    <!-- STICKY LOGO -->
    @if (HasStickyLogo)
    {
        <a href="@HomeUrl" class="wd-logo wd-sticky-logo" rel="home">
            <img src="@StickyLogoUrl"
                 alt="@AltText"
                 style="max-width: @MaxWidth;"
                 loading="lazy"
                 @attributes="AdditionalAttributes">
        </a>
    }
</div>

@code {
    [Parameter]
    public string LogoUrl { get; set; } = string.Empty;

    [Parameter]
    public string StickyLogoUrl { get; set; } = string.Empty;

    [Parameter]
    public string AltText { get; set; } = "لوگوی وب سایت";

    [Parameter]
    public string HomeUrl { get; set; } = "./";

    [Parameter]
    public string MaxWidth { get; set; } = "180px";

    [Parameter]
    public string CssClass { get; set; } = string.Empty;

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool HasStickyLogo => !string.IsNullOrEmpty(StickyLogoUrl);
    private string ResolvedLogoUrl => string.IsNullOrWhiteSpace(LogoUrl) ? "Logo/LOGO.svg" : LogoUrl;
    private bool Use3DLogo => ResolvedLogoUrl.EndsWith(".svg", StringComparison.OrdinalIgnoreCase);
    private ElementReference logoRoot;

    private IJSObjectReference? _jsModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Use3DLogo)
        {
            try
            {
                _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./JS/Rotate.JS");

                await _jsModule.InvokeVoidAsync("init3DLogo", logoRoot);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"JS Load Error: {ex.Message}");
            }
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("dispose3DLogo", logoRoot);
                await _jsModule.DisposeAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Disposal Error: {ex.Message}");
            }
        }
    }
}
