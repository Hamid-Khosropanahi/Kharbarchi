    [HttpGet("source-table-summary")]
    public async Task<IActionResult> SourceTableSummary([FromQuery] string? tableName, CancellationToken cancellationToken = default)
    {
        var safeTableName = NormalizeTableName(tableName);
        await using var connection = new MySqlConnection(GetConnectionString());
        await connection.OpenAsync(cancellationToken);
        await EnsureAllProductTableAsync(connection, safeTableName, cancellationToken);

        await using var command = connection.CreateCommand();
        command.CommandText = $@"
SELECT
    COUNT(*) AS TotalRows,
    COUNT(DISTINCT MainProductName) AS MainProducts,
    COUNT(DISTINCT ProductName) AS ProductNames,
    SUM(CASE WHEN IFNULL(Status, '') IN ('draft','private','disabled') THEN 1 ELSE 0 END) AS DisabledRows
FROM `{safeTableName}`;";

        await using var reader = await command.ExecuteReaderAsync(cancellationToken);
        if (!await reader.ReadAsync(cancellationToken)) return Ok(new { totalRows = 0 });

        return Ok(new
        {
            tableName = safeTableName,
            totalRows = ReadInt64(reader, 0),
            mainProducts = ReadInt64(reader, 1),
            productNames = ReadInt64(reader, 2),
            disabledRows = ReadInt64(reader, 3)
        });
    }

    [HttpGet("sale-products")]
    public async Task<IActionResult> GetSaleProducts(
        [FromQuery] int page = 1,
        [FromQuery] int pageSize = 50,
        [FromQuery] string? search = null,
        CancellationToken cancellationToken = default)
    {
        page = Math.Max(1, page);
        pageSize = Math.Clamp(pageSize, 10, 500);
        var offset = (page - 1) * pageSize;

        await using var connection = new MySqlConnection(GetConnectionString());
        await connection.OpenAsync(cancellationToken);
        await EnsureKharbarchiWorkflowTablesAsync(connection, cancellationToken);

        var where = string.IsNullOrWhiteSpace(search)
            ? string.Empty
            : @"WHERE p.ProductNameFa LIKE @Search
                  OR p.ProductNameEn LIKE @Search
                  OR p.SKU LIKE @Search
                  OR p.ProductSlug LIKE @Search
                  OR c.CategoryNameFa LIKE @Search
                  OR cm.CommodityNameFa LIKE @Search
                  OR pkg.PackageNameFa LIKE @Search";

        long total;
        await using (var count = connection.CreateCommand())
        {
            count.CommandText = $@"
SELECT COUNT(*)
FROM `{ProductFinalTableName}` p
LEFT JOIN `{CategoryTableName}` c ON c.Id = p.CategoryId
LEFT JOIN `{CommodityTableName}` cm ON cm.Id = p.CommodityId
LEFT JOIN `{PackageTableName}` pkg ON pkg.Id = p.PackageTypeId
{where};";
            if (!string.IsNullOrWhiteSpace(search)) Add(count, "@Search", $"%{search}%");
            total = Convert.ToInt64(await count.ExecuteScalarAsync(cancellationToken), CultureInfo.InvariantCulture);
        }

        var items = new List<object>();
        await using (var command = connection.CreateCommand())
        {
            command.CommandText = $@"
SELECT
    p.Id,
    p.WooProductId,
    p.ProductNameFa,
    p.ProductNameEn,
    p.SKU,
    p.ProductSlug,
    c.CategoryNameFa,
    c.CategorySlug,
    cm.CommodityNameFa,
    cm.CommoditySlug,
    pkg.PackageNameFa,
    pkg.PackageCode,
    pkg.PackageGroup,
    p.UnitWeightKg,
    p.PacksPerCarton,
    p.PackagingPricePerPackToman,
    p.KgCashPriceToman,
    p.KgCreditPriceToman,
    p.SalePriceCashToman,
    p.SalePriceCreditToman,
    p.PurchasePriceCashToman,
    p.PurchasePriceCreditToman,
    p.PriceInputUnit,
    p.Status,
    p.ImageUrl,
    p.UpdatedAtUtc
FROM `{ProductFinalTableName}` p
LEFT JOIN `{CategoryTableName}` c ON c.Id = p.CategoryId
LEFT JOIN `{CommodityTableName}` cm ON cm.Id = p.CommodityId
LEFT JOIN `{PackageTableName}` pkg ON pkg.Id = p.PackageTypeId
{where}
ORDER BY p.Id DESC
LIMIT @Take OFFSET @Skip;";
            if (!string.IsNullOrWhiteSpace(search)) Add(command, "@Search", $"%{search}%");
            Add(command, "@Take", pageSize);
            Add(command, "@Skip", offset);

            await using var reader = await command.ExecuteReaderAsync(cancellationToken);
            while (await reader.ReadAsync(cancellationToken))
            {
                items.Add(new
                {
                    id = reader.GetInt64(0),
                    wooProductId = ReadNullableLong(reader, 1),
                    productName = ReadString(reader, 2),
                    productEnglishName = ReadString(reader, 3),
                    sku = ReadString(reader, 4),
                    productSlug = ReadString(reader, 5),
                    categoryName = ReadString(reader, 6),
                    categorySlug = ReadString(reader, 7),
                    mainProductName = ReadString(reader, 8),
                    commoditySlug = ReadString(reader, 9),
                    packageName = ReadString(reader, 10),
                    packageCode = ReadString(reader, 11),
                    packagingGroup = ReadString(reader, 12),
                    unitWeight = ReadNullableDecimal(reader, 13),
                    cartonQuantity = ReadNullableInt(reader, 14),
                    packagingPricePerPack = ReadNullableDecimal(reader, 15),
                    kgPriceCash = ReadNullableDecimal(reader, 16),
                    kgPriceInstallment = ReadNullableDecimal(reader, 17),
                    salePriceCash = ReadNullableDecimal(reader, 18),
                    salePriceInstallment = ReadNullableDecimal(reader, 19),
                    purchasePriceCash = ReadNullableDecimal(reader, 20),
                    purchasePriceInstallment = ReadNullableDecimal(reader, 21),
                    priceInputUnit = ReadString(reader, 22),
                    status = ReadString(reader, 23),
                    imageUrl = ReadString(reader, 24),
                    updatedAtUtc = reader.IsDBNull(25) ? null : reader.GetDateTime(25).ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)
                });
            }
        }

        return Ok(new { page, pageSize, total, items });
    }

    private static async Task<string> UpsertImportedSourceRowAsync(
        MySqlConnection connection,
        string tableName,
        string batchId,
        int sourceRowNumber,
        string rowHash,
        string rawJson,
        ProductMappedRow mapped,
        CancellationToken cancellationToken)
    {
        await using var command = connection.CreateCommand();
        command.CommandText = $@"
INSERT INTO `{tableName}`
(
    ImportBatchId, SourceRowNumber, SourceRowHash, RawJson,
    RowNumber, MainProductName, MainProductEnglishName, MainProductSlug,
    GroupName, CategoryName, CategorySlug,
    ProductName, ProductEnglishName, ProductSlug, SKU,
    BrandName, BrandEnglishName, PackageName, UnitWeight,
    PacksPerCarton, CartonQuantity, PackagingPricePerPack,
    SalePriceCash, SalePriceInstallment, PurchasePriceCash, PurchasePriceInstallment,
    ShortDescription, FullDescription, ImageUrl, GalleryJson, Status,
    WooProductId, HaveOtherPackage, PackageOne,
    CreatedAtUtc, UpdatedAtUtc
)
VALUES
(
    @ImportBatchId, @SourceRowNumber, @SourceRowHash, @RawJson,
    @RowNumber, @MainProductName, @MainProductEnglishName, @MainProductSlug,
    @GroupName, @CategoryName, @CategorySlug,
    @ProductName, @ProductEnglishName, @ProductSlug, @SKU,
    @BrandName, @BrandEnglishName, @PackageName, @UnitWeight,
    @PacksPerCarton, @CartonQuantity, @PackagingPricePerPack,
    @SalePriceCash, @SalePriceInstallment, @PurchasePriceCash, @PurchasePriceInstallment,
    @ShortDescription, @FullDescription, @ImageUrl, @GalleryJson, @Status,
    @WooProductId, @HaveOtherPackage, @PackageOne,
    UTC_TIMESTAMP(6), UTC_TIMESTAMP(6)
)
ON DUPLICATE KEY UPDATE
    ImportBatchId = VALUES(ImportBatchId),
    SourceRowNumber = VALUES(SourceRowNumber),
    RawJson = VALUES(RawJson),
    RowNumber = VALUES(RowNumber),
    MainProductName = VALUES(MainProductName),
    MainProductEnglishName = VALUES(MainProductEnglishName),
    MainProductSlug = VALUES(MainProductSlug),
    GroupName = VALUES(GroupName),
    CategoryName = VALUES(CategoryName),
    CategorySlug = VALUES(CategorySlug),
    ProductName = VALUES(ProductName),
    ProductEnglishName = VALUES(ProductEnglishName),
    ProductSlug = VALUES(ProductSlug),
    SKU = VALUES(SKU),
    BrandName = VALUES(BrandName),
    BrandEnglishName = VALUES(BrandEnglishName),
    PackageName = VALUES(PackageName),
    UnitWeight = VALUES(UnitWeight),
    PacksPerCarton = VALUES(PacksPerCarton),
    CartonQuantity = VALUES(CartonQuantity),
    PackagingPricePerPack = VALUES(PackagingPricePerPack),
    SalePriceCash = VALUES(SalePriceCash),
    SalePriceInstallment = VALUES(SalePriceInstallment),
    PurchasePriceCash = VALUES(PurchasePriceCash),
    PurchasePriceInstallment = VALUES(PurchasePriceInstallment),
    ShortDescription = VALUES(ShortDescription),
    FullDescription = VALUES(FullDescription),
    ImageUrl = VALUES(ImageUrl),
    GalleryJson = VALUES(GalleryJson),
    Status = VALUES(Status),
    WooProductId = VALUES(WooProductId),
    HaveOtherPackage = VALUES(HaveOtherPackage),
    PackageOne = VALUES(PackageOne),
    UpdatedAtUtc = UTC_TIMESTAMP(6);";

        Add(command, "@ImportBatchId", batchId);
        Add(command, "@SourceRowNumber", sourceRowNumber);
        Add(command, "@SourceRowHash", rowHash);
        Add(command, "@RawJson", rawJson);
        Add(command, "@RowNumber", mapped.RowNumber);
        Add(command, "@MainProductName", mapped.MainProductName);
        Add(command, "@MainProductEnglishName", mapped.MainProductEnglishName);
        Add(command, "@MainProductSlug", mapped.MainProductSlug);
        Add(command, "@GroupName", mapped.GroupName);
        Add(command, "@CategoryName", mapped.CategoryName);
        Add(command, "@CategorySlug", mapped.CategorySlug);
        Add(command, "@ProductName", mapped.ProductName);
        Add(command, "@ProductEnglishName", mapped.ProductEnglishName);
        Add(command, "@ProductSlug", mapped.ProductSlug);
        Add(command, "@SKU", mapped.Sku);
        Add(command, "@BrandName", mapped.BrandName);
        Add(command, "@BrandEnglishName", mapped.BrandEnglishName);
        Add(command, "@PackageName", mapped.PackageName);
        Add(command, "@UnitWeight", mapped.UnitWeight);
        Add(command, "@PacksPerCarton", mapped.PacksPerCarton);
        Add(command, "@CartonQuantity", mapped.CartonQuantity);
        Add(command, "@PackagingPricePerPack", mapped.PackagingPricePerPack);
        Add(command, "@SalePriceCash", mapped.SaleKgPriceCash);
        Add(command, "@SalePriceInstallment", mapped.SaleKgPriceInstallment);
        Add(command, "@PurchasePriceCash", mapped.PurchaseKgPriceCash);
        Add(command, "@PurchasePriceInstallment", mapped.PurchaseKgPriceInstallment);
        Add(command, "@ShortDescription", mapped.ShortDescription);
        Add(command, "@FullDescription", mapped.FullDescription);
        Add(command, "@ImageUrl", mapped.ImageUrl);
        Add(command, "@GalleryJson", mapped.GalleryJson);
        Add(command, "@Status", mapped.Status);
        Add(command, "@WooProductId", mapped.WooProductId);
        Add(command, "@HaveOtherPackage", mapped.HaveOtherPackage);
        Add(command, "@PackageOne", mapped.PackageOne);

        var before = await CountByHashAsync(connection, tableName, rowHash, cancellationToken);
        await command.ExecuteNonQueryAsync(cancellationToken);
        return before == 0 ? "insert" : "update";
    }

    private static async Task<List<AllProductRow>> LoadAllProductRowsAsync(MySqlConnection connection, string tableName, CancellationToken cancellationToken)
    {
        var rows = new List<AllProductRow>();
        await using var select = connection.CreateCommand();
        select.CommandText = $@"
SELECT
    Id, SourceRowHash, RowNumber,
    MainProductName, MainProductEnglishName, MainProductSlug,
    GroupName, CategoryName, CategorySlug,
    ProductName, ProductEnglishName, ProductSlug, SKU,
    BrandName, BrandEnglishName, PackageName, UnitWeight,
    PacksPerCarton, CartonQuantity, PackagingPricePerPack,
    SalePriceCash, SalePriceInstallment, PurchasePriceCash, PurchasePriceInstallment,
    ShortDescription, FullDescription, ImageUrl, GalleryJson, Status,
    WooProductId, HaveOtherPackage, PackageOne, RawJson
FROM `{tableName}`
ORDER BY Id;";
        await using var reader = await select.ExecuteReaderAsync(cancellationToken);
        while (await reader.ReadAsync(cancellationToken))
        {
            rows.Add(AllProductRow.From(reader));
        }
        return rows;
    }

    private static ProductMappedRow NormalizeImportedRow(ProductMappedRow row)
    {
        var productEnglish = FirstNotEmpty(row.ProductEnglishName, TranslateProductName(row.ProductName));
        var mainEnglish = FirstNotEmpty(row.MainProductEnglishName, TranslateCommodityName(row.MainProductName), TranslateCommodityName(row.GroupName));
        var categorySlug = NormalizeSlug(FirstNotEmpty(row.CategorySlug, Slugify(FirstNotEmpty(mainEnglish, row.CategoryName, row.MainProductName))));
        var mainSlug = NormalizeSlug(FirstNotEmpty(row.MainProductSlug, Slugify(FirstNotEmpty(mainEnglish, row.MainProductName, row.CategoryName))));
        var productSlug = NormalizeSlug(FirstNotEmpty(row.ProductSlug, Slugify(productEnglish)));
        var packageName = FirstNotEmpty(row.PackageName, row.PackageOne);
        var weight = row.UnitWeight ?? ExtractFirstDecimal(packageName) ?? ExtractFirstDecimal(row.PackageOne);
        var status = FirstNotEmpty(row.Status, (row.SaleKgPriceInstallment ?? 0m) > 0 ? "publish" : "draft");

        return row with
        {
            ProductEnglishName = productEnglish,
            MainProductEnglishName = mainEnglish,
            MainProductSlug = mainSlug,
            CategorySlug = categorySlug,
            ProductSlug = productSlug,
            PackageName = packageName,
            UnitWeight = weight,
            CartonQuantity = row.CartonQuantity ?? row.PacksPerCarton,
            PacksPerCarton = row.PacksPerCarton ?? row.CartonQuantity,
            Status = status
        };
    }

    private static CategoryDraft BuildCategoryDraft(AllProductRow row)
    {
        var slug = NormalizeSlug(FirstNotEmpty(row.CategorySlug, row.MainProductSlug, Slugify(row.CategoryName)));
        var nameFa = FirstNotEmpty(row.CategoryName, row.MainProductName, row.GroupName, "بدون دسته بندی");
        var nameEn = FirstNotEmpty(TranslateCategorySlugToEnglish(slug), row.MainProductEnglishName, SlugToTitle(slug));
        return new CategoryDraft(SourceKey: "cat:" + slug, CategoryNameFa: nameFa, CategoryNameEn: nameEn, CategorySlug: slug);
    }

    private static CommodityDraft BuildCommodityDraft(AllProductRow row, long categoryId)
    {
        var nameFa = FirstNotEmpty(row.MainProductName, row.GroupName, row.CategoryName, row.ProductName, "بدون کالای اصلی");
        var nameEn = FirstNotEmpty(row.MainProductEnglishName, TranslateCommodityName(nameFa), SlugToTitle(row.CategorySlug));
        var slug = NormalizeSlug(FirstNotEmpty(row.MainProductSlug, Slugify(nameEn), row.CategorySlug));
        return new CommodityDraft(SourceKey: "com:" + slug, CategoryId: categoryId, CommodityNameFa: nameFa, CommodityNameEn: nameEn, CommoditySlug: slug);
    }

    private static PackageDraft BuildPackageDraft(ProductFinalDraft product)
    {
        return new PackageDraft(
            SourceKey: "pkg:" + product.PackageCode,
            PackageNameFa: product.PackageNameFa,
            PackageNameEn: product.PackageNameEn,
            PackageCode: product.PackageCode,
            PackageGroup: product.PackageGroup,
            UnitWeightKg: product.UnitWeightKg,
            PacksPerCarton: product.PacksPerCarton,
            PackagingPricePerPackToman: product.PackagingPricePerPackToman,
            ImageTag: product.PackageNameFa);
    }

    private static IEnumerable<ProductFinalDraft> BuildFinalProducts(AllProductRow row, long categoryId, long commodityId)
    {
        var productNameFa = FirstNotEmpty(row.ProductName, row.MainProductName, "محصول");
        var productNameEn = FirstNotEmpty(row.ProductEnglishName, TranslateProductName(productNameFa), SlugToTitle(row.CategorySlug));
        var bulkWeight = row.UnitWeight ?? ExtractFirstDecimal(row.PackageName) ?? ExtractFirstDecimal(row.PackageOne) ?? 0m;
        var hasBulk = bulkWeight > 0 && !string.Equals(FirstNotEmpty(row.PackageName, row.PackageOne), "-", StringComparison.OrdinalIgnoreCase);

        if (hasBulk)
        {
            var bulkPackageFa = FirstNotEmpty(row.PackageName, row.PackageOne, bulkWeight.ToString("0.###", CultureInfo.InvariantCulture) + " kg");
            var bulkCode = "B" + bulkWeight.ToString("0.###", CultureInfo.InvariantCulture).Replace(".", "_");
            yield return BuildOneFinal(row, categoryId, commodityId, productNameFa, productNameEn, bulkPackageFa, bulkWeight.ToString("0.###", CultureInfo.InvariantCulture) + " kg bulk carton", "bulk", bulkCode, bulkWeight, 1, 0m);
        }
        else
        {
            yield return BuildOneFinal(row, categoryId, commodityId, productNameFa, productNameEn, "بدون بسته بندی", "no package", "none", "NOPKG", 1m, 1, 0m);
        }

        if (row.HaveOtherPackage == 1)
        {
            var fee = row.PackagingPricePerPackToman ?? DefaultRetailPackagingFeePerPackToman;
            yield return BuildOneFinal(row, categoryId, commodityId, productNameFa, productNameEn, "450 گرمی کارتن 12 عددی", "450g carton of 12 packs", "retail", "450", 0.45m, 12, fee);
            yield return BuildOneFinal(row, categoryId, commodityId, productNameFa, productNameEn, "900 گرمی کارتن 6 عددی", "900g carton of 6 packs", "retail", "900", 0.90m, 6, fee);
        }
    }

    private static ProductFinalDraft BuildOneFinal(
        AllProductRow row,
        long categoryId,
        long commodityId,
        string productNameFa,
        string productNameEn,
        string packageNameFa,
        string packageNameEn,
        string packageGroup,
        string packageCode,
        decimal unitWeight,
        int packsPerCarton,
        decimal packagingPricePerPackToman)
    {
        var kgCash = row.SaleKgPriceCashToman;
        var kgCredit = row.SaleKgPriceInstallmentToman;
        var saleCash = CalculateFinalPrice(kgCash, unitWeight, packsPerCarton, packagingPricePerPackToman, packageGroup);
        var saleCredit = CalculateFinalPrice(kgCredit, unitWeight, packsPerCarton, packagingPricePerPackToman, packageGroup);
        var buyCash = CalculateFinalPrice(row.PurchaseKgPriceCashToman, unitWeight, packsPerCarton, 0m, packageGroup);
        var buyCredit = CalculateFinalPrice(row.PurchaseKgPriceInstallmentToman, unitWeight, packsPerCarton, 0m, packageGroup);
        var status = NormalizeStatus(row.Status, saleCash, saleCredit);
        var baseSlug = NormalizeSlug(FirstNotEmpty(row.ProductSlug, Slugify(productNameEn)));
        var slug = NormalizeSlug(baseSlug + "-" + packageCode.ToLowerInvariant());
        var sku = BuildSku(productNameEn, row.CategorySlug, row.BrandEnglishName, packageCode, row.RowNumber);
        var sourceKey = "prd:" + ComputeSha256(row.SourceRowHash + "|" + packageCode)[..24];
        var nameFa = CombineProductName(productNameFa, packageNameFa);
        var nameEn = CombineProductName(productNameEn, packageNameEn);

        return new ProductFinalDraft(
            Id: 0,
            SourceKey: sourceKey,
            SourceRowHash: row.SourceRowHash,
            SourceRowId: row.Id,
            WooProductId: row.WooProductId,
            CategoryId: categoryId,
            CommodityId: commodityId,
            PackageTypeId: 0,
            ProductNameFa: nameFa,
            ProductNameEn: nameEn,
            ProductSlug: slug,
            SKU: sku,
            BrandNameFa: row.BrandName,
            BrandNameEn: row.BrandEnglishName,
            PackageNameFa: packageNameFa,
            PackageNameEn: packageNameEn,
            PackageGroup: packageGroup,
            PackageCode: packageCode,
            UnitWeightKg: unitWeight,
            PacksPerCarton: packsPerCarton,
            PackagingPricePerPackToman: packagingPricePerPackToman,
            KgCashPriceToman: kgCash,
            KgCreditPriceToman: kgCredit,
            SalePriceCashToman: saleCash,
            SalePriceCreditToman: saleCredit,
            PurchasePriceCashToman: buyCash,
            PurchasePriceCreditToman: buyCredit,
            PriceInputUnit: row.PriceInputUnit,
            ShortDescription: row.ShortDescription,
            FullDescription: row.FullDescription,
            ImageUrl: row.ImageUrl,
            GalleryJson: row.GalleryJson,
            Status: status);
    }

    private static decimal? CalculateFinalPrice(decimal? kgPriceToman, decimal unitWeightKg, int packsPerCarton, decimal packagingFeePerPackToman, string packageGroup)
    {
        if (!kgPriceToman.HasValue || kgPriceToman.Value <= 0) return null;

        if (string.Equals(packageGroup, "retail", StringComparison.OrdinalIgnoreCase))
        {
            return Math.Round(packsPerCarton * ((kgPriceToman.Value * unitWeightKg) + packagingFeePerPackToman), 0);
        }

        return Math.Round(unitWeightKg * kgPriceToman.Value, 0);
    }

