    private static string TranslateCategorySlugToEnglish(string? slug)
    {
        var key = NormalizeSlug(slug).Replace('-', '_', StringComparison.Ordinal);
        return CategoryEnglishMap.TryGetValue(key, out var value) ? value : string.Empty;
