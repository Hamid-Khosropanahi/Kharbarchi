        await ClearGeneratedTablesAsync(connection, cancellationToken);
        return Ok(new { success = true, message = "Generated KHB tables were cleared." });
    }

    [HttpPost("process-all-product-with-process")]
    public async Task<IActionResult> ProcessAllProductWithProcess(
        [FromQuery] string? tableName,
        [FromQuery] string? priceUnit = "rial",
        [FromQuery] bool clearTargets = false,
        CancellationToken cancellationToken = default)
    {
        var safeTableName = NormalizeTableName(tableName);
        var normalizedPriceUnit = NormalizePriceUnit(priceUnit);

        await using var connection = new MySqlConnection(GetConnectionString());
        await connection.OpenAsync(cancellationToken);

        await EnsureAllProductTableAsync(connection, safeTableName, cancellationToken);
        await EnsureKharbarchiWorkflowTablesAsync(connection, cancellationToken);

        if (clearTargets)
        {
            await ClearGeneratedTablesAsync(connection, cancellationToken);
        }

        var rows = await LoadAllProductRowsAsync(connection, safeTableName, cancellationToken);

        var categoriesTouched = 0;
        var commoditiesTouched = 0;
        var packagesTouched = 0;
        var productsTouched = 0;
        var inactiveProducts = 0;
        var queueTouched = 0;

        foreach (var originalRow in rows)
        {
            var row = originalRow.WithPriceUnit(normalizedPriceUnit);
            await UpsertSourceProductAsync(connection, row, normalizedPriceUnit, cancellationToken);

            var category = BuildCategoryDraft(row);
            var categoryId = await UpsertCategoryAsync(connection, category, cancellationToken);
            categoriesTouched++;

            var commodity = BuildCommodityDraft(row, categoryId);
            var commodityId = await UpsertCommodityAsync(connection, commodity, cancellationToken);
            commoditiesTouched++;

            foreach (var product in BuildFinalProducts(row, categoryId, commodityId))
            {
                var packageId = await UpsertPackageAsync(connection, BuildPackageDraft(product), cancellationToken);
                packagesTouched++;

                var finalProductId = await UpsertFinalProductAsync(connection, product with { PackageTypeId = packageId }, cancellationToken);
                productsTouched++;
                if (!string.Equals(product.Status, "publish", StringComparison.OrdinalIgnoreCase)) inactiveProducts++;

                queueTouched += await UpsertQueueRowsAsync(connection, category, commodity, product with { Id = finalProductId, PackageTypeId = packageId }, normalizedPriceUnit, cancellationToken);
            }
        }

        return Ok(new
        {
            tableName = safeTableName,
            sourceRows = rows.Count,
            priceUnit = normalizedPriceUnit,
            priceUnitText = normalizedPriceUnit == "rial" ? "Input is Rial; kg prices were divided by 10 and stored in Toman." : "Input is Toman; kg prices were stored without conversion.",
            clearTargets,
            categoriesTouched,
            commoditiesTouched,
            packagesTouched,
            productsTouched,
            inactiveProducts,
            queueTouched,
            tables = new[] { SourceTableName, CategoryTableName, CommodityTableName, PackageTableName, ProductFinalTableName, QueueTableName },
            pricingRule = "bulk = kg price toman * kg; retail = packs per carton * ((kg price toman * unit kg) + packaging fee toman per pack)"
        });
    }

