            {
                name = commodity.CommodityNameFa,
                english_name = commodity.CommodityNameEn,
                slug = commodity.CommoditySlug,
                category_slug = category.CategorySlug
            }, JsonOptions)),
            new QueueDraft("package", "pkg:" + product.PackageCode, product.PackageCode, JsonSerializer.Serialize(new
            {
                title = product.PackageNameFa,
                slug = product.PackageCode.ToLowerInvariant(),
                meta = new
