                }
            }, JsonOptions)),
            new QueueDraft("product", product.SourceKey, product.SKU, JsonSerializer.Serialize(BuildWooProductPayload(category, commodity, product, priceUnit), JsonOptions))
        };

        var count = 0;
        foreach (var row in rows)
