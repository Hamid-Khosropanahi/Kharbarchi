        {
            name = product.ProductNameFa,
            type = "simple",
            status = product.Status,
            slug = product.ProductSlug,
            sku = product.SKU,
            regular_price = regularPrice?.ToString("0", CultureInfo.InvariantCulture) ?? string.Empty,
            price = regularPrice?.ToString("0", CultureInfo.InvariantCulture) ?? string.Empty,
            sale_price = string.Empty,
            catalog_visibility = string.Equals(product.Status, "publish", StringComparison.OrdinalIgnoreCase) ? "visible" : "hidden",
            description = product.FullDescription,
            short_description = product.ShortDescription,
            categories = new[] { new { slug = category.CategorySlug, name = category.CategoryNameFa } },
